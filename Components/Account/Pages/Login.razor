@page "/Account/Login"
@layout BlankLayout
@using System.ComponentModel.DataAnnotations
@using LoadManagementSystem_LMS_.Data
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using LoadManagementSystem_LMS_.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Login | LMS</PageTitle>

<style>
    /* ===== Reset and base ===== */
    .login-page {
        font-family: "Segoe UI", Tahoma, sans-serif;
        width: 100%;
    }

    /* ===== Brand ===== */
    .brand {
        text-align: center;
        margin-bottom: 2rem;
    }

        .brand .logo {
            font-size: 2.4rem;
            color: #1a2639;
        }

            .brand .logo i {
                background: #f5c842;
                padding: 0.7rem;
                border-radius: 50%;
                color: #1a2639;
                font-size: 2rem;
            }

        .brand .title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a2639;
            margin-top: 0.5rem;
            letter-spacing: 0.5px;
        }

        .brand .subtitle {
            font-size: 0.9rem;
            color: #6c7a8a;
            font-weight: 300;
        }

    /* ===== Form fields ===== */
    .form-floating {
        margin-bottom: 1.25rem;
    }

        .form-floating label {
            color: #6c7a8a;
        }

    .form-control {
        border-radius: 0.6rem;
        border: 1px solid #dce3ec;
        height: 3.2rem;
        background: #f8fafc;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus {
            border-color: #f5c842;
            box-shadow: 0 0 0 0.2rem rgba(245,200,66,0.25);
            background: #fff;
        }

    .validation-message {
        font-size: 0.85rem;
        color: #dc3545;
        margin-top: 0.3rem;
    }

    /* ===== Checkbox ===== */
    .checkbox {
        margin: 1.25rem 0 1.5rem 0;
    }

        .checkbox label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: #2a3a4e;
            font-weight: 400;
            cursor: pointer;
        }

        .checkbox input[type="checkbox"] {
            width: 1.1rem;
            height: 1.1rem;
            accent-color: #f5c842;
            border-radius: 0.25rem;
            border: 1px solid #bcc9db;
        }

    /* ===== Button ===== */
    .btn-login {
        background: #1a2639;
        border: none;
        border-radius: 0.6rem;
        padding: 0.8rem;
        font-weight: 600;
        font-size: 1rem;
        color: #fff;
        transition: background 0.2s, transform 0.1s;
        width: 100%;
    }

        .btn-login:hover {
            background: #2a3a4e;
            transform: translateY(-1px);
        }

        .btn-login:active {
            transform: scale(0.98);
        }

        .btn-login i {
            margin-right: 0.5rem;
        }

    /* ===== Links ===== */
    .links {
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.95rem;
        color: #4a5a6e;
    }

        .links a {
            color: #1a2639;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }

            .links a:hover {
                color: #f5c842;
                text-decoration: underline;
            }

        .links .separator {
            margin: 0 0.5rem;
            color: #bcc9db;
        }

    /* ===== Error ===== */
    .error-message {
        background: #fee8e8;
        color: #b91c1c;
        border-radius: 0.6rem;
        padding: 0.6rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        border: 1px solid #f5c2c2;
        text-align: center;
    }
</style>

<div class="login-page">
    <!-- Brand -->
    <div class="brand">
        <div class="logo"><i class="bi bi-truck"></i></div>
        <div class="title">LMS</div>
        <div class="subtitle">Load Management System</div>
    </div>

    <!-- Error message -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-message">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
        </div>
    }

    <!-- Login form -->
    <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" role="alert" style="display:none;" />

        <div class="form-floating">
            <InputText @bind-Value="Input.Email"
                       id="email"
                       class="form-control"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="name@example.com" />
            <label for="email">Email Address</label>
            <ValidationMessage For="() => Input.Email" class="validation-message" />
        </div>

        <div class="form-floating">
            <InputText type="password"
                       @bind-Value="Input.Password"
                       id="password"
                       class="form-control"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="password" />
            <label for="password">Password</label>
            <ValidationMessage For="() => Input.Password" class="validation-message" />
        </div>

        <div class="checkbox">
            <label>
                <InputCheckbox @bind-Value="Input.RememberMe" id="rememberMe" />
                Remember Me
            </label>
        </div>

        <button type="submit" class="btn-login">
            <i class="bi bi-box-arrow-in-right"></i> Log In
        </button>
    </EditForm>

    <!-- Additional links -->
    <div class="links">
        <a href="Account/ForgotPassword">Forgot password?</a>
        <span class="separator">|</span>
        <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Create Account</a>
    </div>
</div>

@code {
    private string? errorMessage;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext != null && HttpMethods.IsGet(httpContext.Request.Method))
        {
            // Clear external cookie to ensure clean login
            await httpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        var result = await SignInManager.PasswordSignInAsync(
            Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo("Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Invalid login attempt. Please check your email and password.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}