@page "/Account/ForgotPassword"
@layout BlankLayout
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using LoadManagementSystem_LMS_.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using LoadManagementSystem_LMS_.Models

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Forgot Password | LMS</PageTitle>

<style>
    /* ===== Reset and base ===== */
    .forgot-page {
        font-family: "Segoe UI", Tahoma, sans-serif;
        width: 100%;
    }

    /* ===== Brand ===== */
    .brand {
        text-align: center;
        margin-bottom: 2rem;
    }

        .brand .logo {
            font-size: 2.4rem;
            color: #1a2639;
        }

            .brand .logo i {
                background: #f5c842;
                padding: 0.7rem;
                border-radius: 50%;
                color: #1a2639;
                font-size: 2rem;
            }

        .brand .title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a2639;
            margin-top: 0.5rem;
            letter-spacing: 0.5px;
        }

        .brand .subtitle {
            font-size: 0.9rem;
            color: #6c7a8a;
            font-weight: 300;
        }

    /* ===== Form fields ===== */
    .form-floating {
        margin-bottom: 1.25rem;
    }

        .form-floating label {
            color: #6c7a8a;
        }

    .form-control {
        border-radius: 0.6rem;
        border: 1px solid #dce3ec;
        height: 3.2rem;
        background: #f8fafc;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus {
            border-color: #f5c842;
            box-shadow: 0 0 0 0.2rem rgba(245,200,66,0.25);
            background: #fff;
        }

    .validation-message {
        font-size: 0.85rem;
        color: #dc3545;
        margin-top: 0.3rem;
    }

    /* ===== Button ===== */
    .btn-reset {
        background: #1a2639;
        border: none;
        border-radius: 0.6rem;
        padding: 0.8rem;
        font-weight: 600;
        font-size: 1rem;
        color: #fff;
        transition: background 0.2s, transform 0.1s;
        width: 100%;
    }

        .btn-reset:hover {
            background: #2a3a4e;
            transform: translateY(-1px);
        }

        .btn-reset:active {
            transform: scale(0.98);
        }

        .btn-reset i {
            margin-right: 0.5rem;
        }

    /* ===== Links ===== */
    .links {
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.95rem;
        color: #4a5a6e;
    }

        .links a {
            color: #1a2639;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }

            .links a:hover {
                color: #f5c842;
                text-decoration: underline;
            }

        .links .separator {
            margin: 0 0.5rem;
            color: #bcc9db;
        }

    /* ===== Info text ===== */
    .info-text {
        text-align: center;
        color: #4a5a6e;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    /* ===== Success/Error ===== */
    .success-message, .error-message {
        border-radius: 0.6rem;
        padding: 0.6rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        text-align: center;
    }

    .success-message {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .error-message {
        background: #fee8e8;
        color: #b91c1c;
        border: 1px solid #f5c2c2;
    }
</style>

<div class="forgot-page">
    <!-- Brand -->
    <div class="brand">
        <div class="logo"><i class="bi bi-truck"></i></div>
        <div class="title">LMS</div>
        <div class="subtitle">Load Management System</div>
    </div>

    <!-- Status messages -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="success-message">
            <i class="bi bi-check-circle-fill me-2"></i> @successMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-message">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
        </div>
    }

    <!-- Info text -->
    <div class="info-text">
        Enter your email address and we'll send you a link to reset your password.
    </div>

    <!-- Forgot password form -->
    <EditForm Model="Input" OnValidSubmit="OnValidSubmitAsync" FormName="forgot-password">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" role="alert" style="display:none;" />

        <div class="form-floating">
            <InputText @bind-Value="Input.Email"
                       id="email"
                       class="form-control"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="name@example.com" />
            <label for="email">Email Address</label>
            <ValidationMessage For="() => Input.Email" class="validation-message" />
        </div>

        <button type="submit" class="btn-reset">
            <i class="bi bi-envelope-paper"></i> Send Reset Link
        </button>
    </EditForm>

    <!-- Links -->
    <div class="links">
        <a href="Account/Login">Back to Login</a>
        <span class="separator">|</span>
        <a href="Account/Register">Create Account</a>
    </div>
</div>

@code {
    private string? successMessage;
    private string? errorMessage;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null || !(await UserManager.IsEmailConfirmedAsync(user)))
        {
            // Don't reveal that the user does not exist or is not confirmed.
            // Redirect to confirmation page (or show a generic success message).
            successMessage = "If an account exists with this email, a password reset link has been sent.";
            errorMessage = null;
            Input = new InputModel(); // clear form
            return;
        }

        // Generate reset token and send email
        var code = await UserManager.GeneratePasswordResetTokenAsync(user);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = NavigationManager.GetUriWithQueryParameters(
            NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
            new Dictionary<string, object?> { ["code"] = code });

        await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));

        // Show success message (or redirect to confirmation page)
        successMessage = "A password reset link has been sent to your email. Please check your inbox.";
        errorMessage = null;
        Input = new InputModel(); // clear form
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";
    }
}