@page "/Account/Register"
@layout BlankLayout
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using LoadManagementSystem_LMS_.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using LoadManagementSystem_LMS_.Models

@inject UserManager<ApplicationUser> UserManager
@inject IUserStore<ApplicationUser> UserStore
@inject SignInManager<ApplicationUser> SignInManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject ILogger<Register> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Register | LMS</PageTitle>

<style>
    /* ===== Reset and base ===== */
    .register-page {
        font-family: "Segoe UI", Tahoma, sans-serif;
        width: 100%;
    }

    /* ===== Brand ===== */
    .brand {
        text-align: center;
        margin-bottom: 2rem;
    }

        .brand .logo {
            font-size: 2.4rem;
            color: #1a2639;
        }

            .brand .logo i {
                background: #f5c842;
                padding: 0.7rem;
                border-radius: 50%;
                color: #1a2639;
                font-size: 2rem;
            }

        .brand .title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a2639;
            margin-top: 0.5rem;
            letter-spacing: 0.5px;
        }

        .brand .subtitle {
            font-size: 0.9rem;
            color: #6c7a8a;
            font-weight: 300;
        }

    /* ===== Form fields ===== */
    .form-floating {
        margin-bottom: 1.25rem;
    }

        .form-floating label {
            color: #6c7a8a;
        }

    .form-control {
        border-radius: 0.6rem;
        border: 1px solid #dce3ec;
        height: 3.2rem;
        background: #f8fafc;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus {
            border-color: #f5c842;
            box-shadow: 0 0 0 0.2rem rgba(245,200,66,0.25);
            background: #fff;
        }

    .validation-message {
        font-size: 0.85rem;
        color: #dc3545;
        margin-top: 0.3rem;
    }

    /* ===== Button ===== */
    .btn-register {
        background: #1a2639;
        border: none;
        border-radius: 0.6rem;
        padding: 0.8rem;
        font-weight: 600;
        font-size: 1rem;
        color: #fff;
        transition: background 0.2s, transform 0.1s;
        width: 100%;
    }

        .btn-register:hover {
            background: #2a3a4e;
            transform: translateY(-1px);
        }

        .btn-register:active {
            transform: scale(0.98);
        }

        .btn-register i {
            margin-right: 0.5rem;
        }

    /* ===== Links ===== */
    .links {
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.95rem;
        color: #4a5a6e;
    }

        .links a {
            color: #1a2639;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }

            .links a:hover {
                color: #f5c842;
                text-decoration: underline;
            }

        .links .separator {
            margin: 0 0.5rem;
            color: #bcc9db;
        }

    /* ===== Error ===== */
    .error-message {
        background: #fee8e8;
        color: #b91c1c;
        border-radius: 0.6rem;
        padding: 0.6rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        border: 1px solid #f5c2c2;
        text-align: center;
    }

    /* ===== Success ===== */
    .success-message {
        background: #d4edda;
        color: #155724;
        border-radius: 0.6rem;
        padding: 0.6rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        border: 1px solid #c3e6cb;
        text-align: center;
    }
</style>

<div class="register-page">
    <!-- Brand -->
    <div class="brand">
        <div class="logo"><i class="bi bi-truck"></i></div>
        <div class="title">LMS</div>
        <div class="subtitle">Load Management System</div>
    </div>

    <!-- Error message -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-message">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
        </div>
    }

    <!-- Success message -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="success-message">
            <i class="bi bi-check-circle-fill me-2"></i> @successMessage
        </div>
    }

    <!-- Register form -->
    <EditForm Model="Input" OnValidSubmit="RegisterUser" FormName="register">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" role="alert" style="display:none;" />

        <!-- Full Name -->
        <div class="form-floating">
            <InputText @bind-Value="Input.FullName"
                       id="fullName"
                       class="form-control"
                       placeholder="Full Name"
                       autocomplete="name" />
            <label for="fullName">Full Name</label>
            <ValidationMessage For="() => Input.FullName" class="validation-message" />
        </div>

        <!-- Email -->
        <div class="form-floating">
            <InputText @bind-Value="Input.Email"
                       id="email"
                       class="form-control"
                       placeholder="name@example.com"
                       autocomplete="username" />
            <label for="email">Email Address</label>
            <ValidationMessage For="() => Input.Email" class="validation-message" />
        </div>

        <!-- Password -->
        <div class="form-floating">
            <InputText type="password"
                       @bind-Value="Input.Password"
                       id="password"
                       class="form-control"
                       placeholder="Password"
                       autocomplete="new-password" />
            <label for="password">Password</label>
            <ValidationMessage For="() => Input.Password" class="validation-message" />
        </div>

        <!-- Confirm Password -->
        <div class="form-floating">
            <InputText type="password"
                       @bind-Value="Input.ConfirmPassword"
                       id="confirmPassword"
                       class="form-control"
                       placeholder="Confirm Password"
                       autocomplete="new-password" />
            <label for="confirmPassword">Confirm Password</label>
            <ValidationMessage For="() => Input.ConfirmPassword" class="validation-message" />
        </div>

        <button type="submit" class="btn-register">
            <i class="bi bi-person-plus"></i> Register
        </button>
    </EditForm>

    <!-- Login link -->
    <div class="links">
        Already have an account?
        <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Login", new Dictionary<string, object?> { ["ReturnUrl"] = null }))">
            Log in
        </a>
    </div>
</div>

@code {
    private string? errorMessage;
    private string? successMessage;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    public async Task RegisterUser()
    {
        // Create user with your ApplicationUser model
        var user = new ApplicationUser
        {
            FullName = Input.FullName,
            UserName = Input.Email,
            Email = Input.Email,
            IsActive = true,
            CreatedDate = DateTime.Now
        };

        var result = await UserManager.CreateAsync(user, Input.Password);

        if (result.Succeeded)
        {
            Logger.LogInformation("User created a new account.");

            // Optionally assign a default role (if you have roles later)
            // await UserManager.AddToRoleAsync(user, "User");

            successMessage = "Registration successful! You can now log in.";
            Input = new InputModel(); // clear form
            errorMessage = null;
        }
        else
        {
            errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
            successMessage = null;
        }
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(100)]
        public string FullName { get; set; } = "";

        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [StringLength(100, MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}