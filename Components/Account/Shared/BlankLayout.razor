@inherits LayoutComponentBase

<style>
    /* Full-page layout */
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
        overflow: hidden;
        font-family: "Segoe UI", Roboto, sans-serif;
    }

    /* Background image */
    .blank-layout-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/loads.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: -1;
    }

        /* Dark overlay */
        .blank-layout-bg::after {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
        }

    /* Center content */
    .blank-content {
        position: relative;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem;
    }

    /* Glassmorphic card (SMALLER & TIGHTER) */
    .blank-card {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-radius: 1.4rem; /* reduced */
        padding: 2.2rem 2.6rem; /* unchanged */
        max-width: 28rem; /* reduced from 32rem */
        width: 100%;
        box-shadow: 0 22px 70px rgba(0,0,0,0.35);
        animation: fadeInUp 1s ease-out forwards;
        opacity: 0;
        transition: all 0.3s ease-in-out;
        border: 1px solid rgba(255,255,255,0.3);
    }

        .blank-card:hover {
            box-shadow: 0 32px 85px rgba(0,0,0,0.45);
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Mobile */
    @@media (max-width: 768px) {
        .blank-card {
            width: 100%; /* slightly smaller than 88% */
            padding: 1.8rem 1.8rem;
            border-radius: 1.2rem;
        }
    }

    /* MINIMAL UNDERLINE INPUTS */
    .blank-card .form-control {
        background: transparent !important;
        border: none !important;
        border-bottom: 2px solid rgba(0,0,0,0.7) !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        outline: none !important;
        color: #000;
        padding-left: 0 !important;
        padding-right: 0 !important;
        height: 3.6rem !important; /* reduced */
        font-size: 1.05rem;
    }

        /* Focus underline color */
        .blank-card .form-control:focus {
            border-bottom: 2px solid #000 !important;
        }

    /* Floating label minimalist style */
    .blank-card .form-floating > label {
        color: rgba(0,0,0,0.6);
        font-weight: 500;
        padding-left: 0 !important;
        transform: translateY(0.65rem) scale(1);
        transition: all .2s ease;
    }

    /* Move label up */
    .blank-card .form-control:focus ~ label,
    .blank-card .form-control:not(:placeholder-shown) ~ label {
        transform: translateY(-0.9rem) scale(.85);
        color: #000;
    }

    /* Force input wrapper full width */
    .blank-card .form-floating {
        display: block;
        width: 100% !important;
        margin-bottom: 1.4rem;
    }

    /* Scrollable registration area */
    .register-scroll-area {
        max-height: 70vh; /* reduced */
        overflow-y: auto;
        padding-right: .5rem;
    }

    /* Remove white/yellow autofill background */
    .blank-card input.form-control:-webkit-autofill,
    .blank-card input.form-control:-webkit-autofill:hover,
    .blank-card input.form-control:-webkit-autofill:focus,
    .blank-card input.form-control:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0 50px transparent inset !important;
        -webkit-text-fill-color: #000 !important;
        transition: background-color 9999s ease-in-out 0s;
    }

    /* Force background always transparent */
    .blank-card input.form-control {
        background-color: transparent !important;
    }
</style>

<!-- Background -->
<div class="blank-layout-bg"></div>

<!-- Centered content -->
<div class="blank-content">
    <div class="blank-card">
        @Body
    </div>
</div>
