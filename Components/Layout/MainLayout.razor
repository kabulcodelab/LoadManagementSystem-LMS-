@inherits LayoutComponentBase

<div class="page" style="background: transparent !important;">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main style="background: transparent !important;">
        <article class="content px-4" style="background: transparent !important; padding: 0 !important;">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
