@implements IDisposable
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.Authorization

<style>
    /* ==========================================
           ORIGINAL BRAND STYLES (Completely Preserved)
        ========================================== */
    .verano-sidebar,
    .verano-sidebar * {
        font-family: "Segoe UI", Tahoma, sans-serif !important;
    }

    .verano-sidebar {
        background-color: #0b1a2e !important;
        min-width: 260px;
        height: 100vh;
        display: flex;
        flex-direction: column;
        padding: 1rem; /* Original padding preserved */
        color: #e8edf3 !important;
    }

    .verano-brand .brand-name {
        color: #f5d742 !important;
        font-weight: 700;
        font-size: 1.3rem;
        line-height: 1.2;
        letter-spacing: 0.5px;
    }

    .verano-brand .brand-sub {
        color: #f5d742 !important;
        font-size: 0.7rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.9;
    }

    .verano-divider {
        border-color: rgba(245, 215, 66, 0.4) !important;
        opacity: 0.7;
    }

    .brand-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.25s ease, filter 0.25s ease;
        cursor: default;
        filter: drop-shadow(0 0 10px rgba(245, 215, 66, 0.3));
    }

        .brand-logo:hover {
            transform: scale(1.08);
            filter: drop-shadow(0 0 24px rgba(245, 215, 66, 0.7));
        }

        .brand-logo svg {
            display: block;
        }

    .verano-sidebar .nav-link {
        transition: background-color 0.2s ease-in-out, color 0.2s ease-in-out;
        border-radius: 6px;
        color: #d0d9e6 !important;
        display: flex;
        align-items: center;
        padding: 0.5rem 0.75rem;
        text-decoration: none;
        background: transparent;
        border: none;
        width: 100%;
        text-align: right;
        cursor: pointer;
    }

        .verano-sidebar .nav-link i {
            font-size: 1.1rem;
            margin-left: 0.75rem;
            margin-right: 0.5rem;
            color: #f5d742 !important;
            width: 1.4rem;
            text-align: center;
        }

        .verano-sidebar .nav-link:hover {
            background-color: rgba(245, 215, 66, 0.15) !important;
            color: #fff8e0 !important;
        }

            .verano-sidebar .nav-link:hover i {
                color: #ffe066 !important;
            }

    .verano-sidebar .nav-pills .nav-link.active,
    .verano-sidebar .nav-pills .show > .nav-link {
        background-color: rgba(245, 215, 66, 0.2) !important;
        color: #fff8e0 !important;
        border-right: 3px solid #f5d742;
    }

        .verano-sidebar .nav-pills .nav-link.active i,
        .verano-sidebar .nav-pills .show > .nav-link i {
            color: #ffe066 !important;
        }

    .verano-sidebar .logout-btn {
        background: transparent;
        border: none;
        color: #d0d9e6 !important;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        transition: background-color 0.2s ease-in-out, color 0.2s ease-in-out;
        width: 100%;
        text-align: right;
        display: flex;
        align-items: center;
        cursor: pointer;
    }

        .verano-sidebar .logout-btn i {
            font-size: 1.1rem;
            margin-left: 0.75rem;
            margin-right: 0.5rem;
            color: #f5d742 !important;
            width: 1.4rem;
            text-align: center;
        }

        .verano-sidebar .logout-btn:hover {
            background-color: rgba(245, 215, 66, 0.15) !important;
            color: #fff8e0 !important;
        }

            .verano-sidebar .logout-btn:hover i {
                color: #ffe066 !important;
            }

    .verano-sidebar .hr-gold {
        border-color: rgba(245, 215, 66, 0.3);
        margin: 0.75rem 0;
    }

    .verano-sidebar .nav-scroll {
        overflow-y: auto;
        flex: 1;
        padding: 0.5rem 0;
        transition: all 0.3s ease;
    }

        .verano-sidebar .nav-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .verano-sidebar .nav-scroll::-webkit-scrollbar-track {
            background: #0b1a2e;
        }

        .verano-sidebar .nav-scroll::-webkit-scrollbar-thumb {
            background: #f5d742;
            border-radius: 4px;
        }

    /* ==========================================
           NEW: Hamburger Toggle Button (Non-Intrusive)
        ========================================== */

    /* Brand container – flex to place toggle button on the right */
    .verano-brand-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        /* All original brand styles (mb-3, pb-2, border-bottom) are preserved */
    }

    /* Toggle button – gold themed, visible only on mobile via media query */
    .sidebar-toggle {
        background: transparent;
        border: 1px solid rgba(245, 215, 66, 0.5);
        color: #f5d742;
        font-size: 1.6rem;
        cursor: pointer;
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        transition: background 0.2s, border-color 0.2s;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-left: 0.5rem;
    }

        .sidebar-toggle:hover {
            background: rgba(245, 215, 66, 0.15);
            border-color: #f5d742;
        }

    /* Collapsed menu (hidden) */
    .nav-scroll.collapsed {
        display: none !important;
    }

    /* ==========================================
           RESPONSIVE
        ========================================== */

    /* Mobile (max-width: 768px) */
    @@media (max-width: 768px) {
        .verano-sidebar {
            min-width: 100%;
            max-width: 100%;
            height: auto;
            padding: 0.75rem;
        }
        /* Show toggle button on mobile */
        .sidebar-toggle {
            display: flex !important;
        }
        /* Adjust brand margin on mobile */
        .verano-brand-container {
            margin-bottom: 0.5rem;
            padding-bottom: 0.5rem;
        }

        .nav-scroll {
            max-height: 80vh;
            padding: 0.25rem 0;
        }

        .verano-sidebar .nav-link {
            padding: 0.4rem 0.6rem;
            font-size: 0.9rem;
        }

            .verano-sidebar .nav-link i {
                font-size: 1rem;
                margin-left: 0.5rem;
            }
    }

    /* Desktop & Tablet (>= 769px) */
    @@media (min-width: 769px) {
        /* Hide toggle button on desktop/tablet */
        .sidebar-toggle {
            display: none !important;
        }
        /* Menu always open (ignore collapsed class) */
        .nav-scroll.collapsed {
            display: block !important;
        }
    }
</style>

<div class="verano-sidebar" dir="ltr">

    <!-- ===== BRAND + TOGGLE BUTTON (Preserved original styling) ===== -->
    <div class="verano-brand-container verano-brand mb-3 pb-2 border-bottom verano-divider">
        <!-- Brand section – completely unchanged -->
        <div class="d-flex align-items-center px-2 py-2" style="cursor:default; gap: 12px;">
            <div class="brand-logo">
                <svg width="52" height="52" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="2" width="52" height="52" rx="14" fill="#0b1a2e" stroke="#f5d742" stroke-width="3" />
                    <path d="M14 18 L28 30 L42 18" stroke="#f5d742" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
                    <rect x="16" y="28" width="24" height="14" rx="2" stroke="#f5d742" stroke-width="3" fill="none" />
                    <line x1="20" y1="34" x2="36" y2="34" stroke="#f5d742" stroke-width="2.5" opacity="0.9" />
                    <circle cx="28" cy="42" r="3" fill="#f5d742" />
                    <circle cx="44" cy="12" r="3" fill="#f5d742" opacity="0.7" />
                </svg>
            </div>
            <div>
                <div class="brand-name">LMS</div>
                <div class="brand-sub">Load Management</div>
            </div>
        </div>

        <!-- Hamburger toggle button (hidden on desktop via CSS) -->
        <button class="sidebar-toggle" @onclick="ToggleMenu" aria-label="Toggle navigation">
            <i class="bi @(isMenuOpen ? "bi-x-lg" : "bi-list")"></i>
        </button>
    </div>

    <!-- ===== NAVIGATION ===== -->
    <div class="nav-scroll @(isMenuOpen ? "" : "collapsed")">
        <nav class="nav nav-pills flex-column nav-gap">

            <AuthorizeView Context="auth">
                <Authorized>
                    <!-- Each link calls CloseMenuIfMobile to auto-close on mobile -->
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-house-door-fill"></i> Dashboard
                    </NavLink>
                    <NavLink class="nav-link" href="/drivers" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-people-fill"></i> Drivers
                    </NavLink>
                    <NavLink class="nav-link" href="/vehicles" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-truck"></i> Vehicles
                    </NavLink>
                    <NavLink class="nav-link" href="/customers" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-buildings"></i> Customers
                    </NavLink>
                    <NavLink class="nav-link" href="/loads" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-box-seam"></i> Loads
                    </NavLink>
                    <NavLink class="nav-link" href="/documents" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-file-earmark"></i> Documents
                    </NavLink>
                    <NavLink class="nav-link" href="/stops" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-geo-alt"></i> Stops
                    </NavLink>

                    <hr class="hr-gold" />

                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <NavLink class="nav-link" href="/admin/users" @onclick="CloseMenuIfMobile">
                                <i class="bi bi-people"></i> User Management
                            </NavLink>
                        </Authorized>
                    </AuthorizeView>

                    <NavLink class="nav-link" href="Account/Manage" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-person-fill"></i> Settings
                    </NavLink>

                    <form action="Account/Logout" method="post" class="mt-1">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="logout-btn" @onclick="CloseMenuIfMobile">
                            <i class="bi bi-box-arrow-left"></i> Logout
                        </button>
                    </form>
                </Authorized>

                <NotAuthorized>
                    <NavLink class="nav-link" href="Account/Login" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </NavLink>
                    <NavLink class="nav-link" href="Account/Register" @onclick="CloseMenuIfMobile">
                        <i class="bi bi-person-plus-fill"></i> Register
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>

        </nav>
    </div>
</div>

@code {
    private string? currentUrl;
    private bool isMenuOpen = true;      // Default: open (desktop/tablet)
    private bool isMobile = false;       // Detected after first render
    private DotNetObjectReference<NavMenu>? _dotNetRef;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await DetectMobile();

                // Attach resize event listener
                _dotNetRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("window.addEventListener", "resize", _dotNetRef, "OnWindowResize");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"JS Interop error: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public async Task OnWindowResize()
    {
        await DetectMobile();
        StateHasChanged();
    }

    private async Task DetectMobile()
    {
        bool mobile = await JSRuntime.InvokeAsync<bool>("window.matchMedia", "(max-width: 768px)").AsTask();
        if (mobile != isMobile)
        {
            isMobile = mobile;
            // On mobile: menu closed, on desktop/tablet: menu open
            isMenuOpen = !isMobile;
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private void ToggleMenu()
    {
        if (isMobile)
        {
            isMenuOpen = !isMenuOpen;
            StateHasChanged();
        }
    }

    private void CloseMenuIfMobile()
    {
        if (isMobile)
        {
            isMenuOpen = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        if (_dotNetRef != null)
        {
            try
            {
                JSRuntime.InvokeVoidAsync("window.removeEventListener", "resize", _dotNetRef, "OnWindowResize");
            }
            catch { }
            _dotNetRef.Dispose();
        }
    }
}