@page "/customers"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components

@inject CustomerService CustomerService
@inject NavigationManager Nav

<div class="container-fluid px-3 px-md-4 py-3">

    <!-- HEADER -->
    <div class="row align-items-center mb-4">
        <div class="col-12 col-md-8">
            <h2 class="page-title mb-0">Customers</h2>
            <p class="page-subtitle text-muted mb-0">Manage all customers</p>
        </div>
        <div class="col-12 col-md-4 text-md-end mt-2 mt-md-0">
            <a class="btn btn-add w-100 w-md-auto" href="/customers/create">
                <i class="bi bi-plus-circle"></i> Add Customer
            </a>
        </div>
    </div>

    <!-- ALERT -->
    @if (ShowAlert)
    {
        <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
            <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
            <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
        </div>
    }

    <!-- SEARCH PANEL -->
    <div class="lms-card mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-lg-8">
                <label class="form-label fw-semibold">Search Customer</label>
                <input class="form-control"
                       placeholder="Search by code, name, phone, email..."
                       @bind="search" @bind:event="oninput" />
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex gap-2">
                    <button class="btn btn-lms-primary w-100" @onclick="ApplyFilter">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn btn-secondary w-100" @onclick="Reset">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="lms-card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th class="d-none d-lg-table-cell">Email</th>
                        <th>Status</th>
                        <th class="text-center" style="min-width:130px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pagedResult == null)
                    {
                        <tr><td colspan="6" class="text-center py-4">Loading...</td></tr>
                    }
                    else if (!pagedResult.Items.Any())
                    {
                        <tr><td colspan="6" class="text-center py-4 text-muted">No customers found.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in pagedResult.Items)
                        {
                            <tr>
                                <td><code>@item.CustomerCode</code></td>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.PhoneNumber</td>
                                <td class="d-none d-lg-table-cell">@item.Email</td>
                                <td>
                                    <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                        @(item.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-center flex-nowrap">
                                        <a class="btn btn-sm btn-outline-info" href="/customers/details/@item.Id" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a class="btn btn-sm btn-outline-warning" href="/customers/edit/@item.Id" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(item.Id, item.Name)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @if (pagedResult != null && pagedResult.TotalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3 pt-2 border-top">
                <div class="text-muted small mb-2 mb-md-0">
                    Showing @((pagedResult.CurrentPage - 1) * pagedResult.PageSize + 1) -
                    @Math.Min(pagedResult.CurrentPage * pagedResult.PageSize, pagedResult.TotalCount)
                    of @pagedResult.TotalCount entries
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @for (int i = 1; i <= pagedResult.TotalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(i)">@i</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == pagedResult.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        else if (pagedResult != null && pagedResult.TotalCount > 0)
        {
            <div class="mt-3 pt-2 border-top text-muted small">
                Showing @pagedResult.TotalCount entries
            </div>
        }
    </div>

    <!-- DELETE CONFIRMATION MODAL -->
    @if (DeleteId.HasValue)
    {
        <div class="modal-backdrop fade show" style="display:block;"></div>
        <div class="modal show d-block" tabindex="-1" role="dialog" style="display:block;">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete customer <strong>@DeleteName</strong>?</p>
                        <p class="text-danger">This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger" @onclick="ExecuteDelete">Yes, Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@code {
    // ===== Parameters =====
    [Parameter] public string? Message { get; set; }

    // ===== Fields =====
    private PagedResult<Customer>? pagedResult;
    private string? search;
    private int currentPage = 1;
    private const int PageSize = 10;

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    // Delete confirmation
    private int? DeleteId;
    private string? DeleteName;

    // ===== Lifecycle =====
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Message))
        {
            ShowAlertMessage(Message);
        }
    }

    // ===== Data loading =====
    private async Task LoadData()
    {
        // Ensure CustomerService has GetPaged method
        pagedResult = await CustomerService.GetPaged(currentPage, PageSize, search);
    }

    // ===== Search / Filter =====
    private async Task ApplyFilter()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task Reset()
    {
        search = null;
        currentPage = 1;
        await LoadData();
    }

    // ===== Pagination =====
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > pagedResult?.TotalPages) return;
        currentPage = page;
        await LoadData();
    }

    // ===== Delete =====
    private void ConfirmDelete(int id, string name)
    {
        DeleteId = id;
        DeleteName = name;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        DeleteId = null;
        DeleteName = null;
        StateHasChanged();
    }

    private async Task ExecuteDelete()
    {
        if (DeleteId.HasValue)
        {
            try
            {
                await CustomerService.Delete(DeleteId.Value);
                CancelDelete();
                await LoadData();
                ShowAlertMessage($"Customer '{DeleteName}' was deleted successfully.", isError: false);
            }
            catch (Exception ex)
            {
                ShowAlertMessage($"Error: {ex.Message}", isError: true);
            }
        }
    }

    // ===== Alert helpers =====
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }
}