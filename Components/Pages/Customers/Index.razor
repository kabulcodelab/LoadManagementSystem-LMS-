@page "/customers"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject CustomerService CustomerService

<h3 class="mb-3">Customers</h3>

<a class="btn btn-primary mb-3" href="/customers/create">
    + Add Customer
</a>

<!-- 🔍 SEARCH -->
<div class="card p-3 mb-3 shadow-sm">

    <div class="row">

        <div class="col-md-8">
            <input class="form-control"
                   placeholder="Search by code, name, phone, email..."
                   @bind="search" />
        </div>

        <div class="col-md-4">

            <button class="btn btn-success me-2"
                    @onclick="ApplyFilter">
                Search
            </button>

            <button class="btn btn-secondary"
                    @onclick="Reset">
                Reset
            </button>

        </div>

    </div>

</div>

<!-- TABLE -->
<table class="table table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (customers == null)
        {
            <tr>
                <td colspan="6">Loading...</td>
            </tr>
        }
        else
        {
            @foreach (var c in customers)
            {
                <tr>

                    <td>@c.CustomerCode</td>
                    <td>@c.Name</td>
                    <td>@c.PhoneNumber</td>
                    <td>@c.Email</td>

                    <td>
                        <span class="badge @(c.IsActive ? "bg-success" : "bg-danger")">
                            @(c.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>

                    <td>
                        <a class="btn btn-info btn-sm"
                           href="/customers/details/@c.Id">
                            View
                        </a>

                        <a class="btn btn-sm btn-warning"
                           href="/customers/edit/@c.Id">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                @onclick="() => Delete(c.Id)">
                            Delete
                        </button>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>
@code {

    List<Customer>? customers;
    string? search;

    protected override async Task OnInitializedAsync()
    {
        customers = await CustomerService.GetFiltered(null);
    }

    async Task ApplyFilter()
    {
        customers = await CustomerService.GetFiltered(search);
    }

    async Task Reset()
    {
        search = null;
        customers = await CustomerService.GetFiltered(null);
    }

    private async Task Delete(int id)
    {
        await CustomerService.Delete(id);
        customers = await CustomerService.GetFiltered(search);
    }
}