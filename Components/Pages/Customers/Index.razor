@page "/customers"
@attribute [Authorize]
@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject CustomerService CustomerService

<PageTitle>Customers</PageTitle>

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header d-flex justify-content-between align-items-center">

        <div>
            <div class="page-title">Customers</div>
            <div class="page-subtitle">Manage all customers</div>
        </div>

        <a class="btn btn-add" href="/customers/create">
            + Add Customer
        </a>

    </div>

    <!-- SEARCH PANEL -->
    <div class="search-panel">

        <div class="row g-2">

            <div class="col-md-8 col-12">
                <input class="form-control"
                       placeholder="Search by code, name, phone, email..."
                       @bind="search" />
            </div>

            <div class="col-md-4 col-12 d-flex gap-2">

                <button class="btn btn-lms-primary flex-fill"
                        @onclick="ApplyFilter">
                    Search
                </button>

                <button class="btn btn-secondary flex-fill"
                        @onclick="Reset">
                    Reset
                </button>

            </div>

        </div>

    </div>

    <!-- TABLE -->
    <div class="lms-card table-responsive">

        <table class="table lms-table">

            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (customers == null)
                {
                    <tr>
                        <td colspan="6">Loading...</td>
                    </tr>
                }
                else if (customers.Count == 0)
                {
                    <tr>
                        <td colspan="6">No customers found</td>
                    </tr>
                }
                else
                {
                    @foreach (var c in customers)
                    {
                        <tr>

                            <td>@c.CustomerCode</td>
                            <td>@c.Name</td>
                            <td>@c.PhoneNumber</td>
                            <td>@c.Email</td>

                            <td>
                                <span class="badge @(c.IsActive ? "bg-success" : "bg-danger")">
                                    @(c.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>

                            <td class="text-end">

                                <a class="btn btn-sm btn-info"
                                   href="/customers/details/@c.Id">
                                    View
                                </a>

                                <a class="btn btn-sm btn-warning"
                                   href="/customers/edit/@c.Id">
                                    Edit
                                </a>

                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => Delete(c.Id)">
                                    Delete
                                </button>

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>

@code {

    List<Customer>? customers;
    string? search;

    protected override async Task OnInitializedAsync()
    {
        customers = await CustomerService.GetFiltered(null);
    }

    async Task ApplyFilter()
    {
        customers = await CustomerService.GetFiltered(search);
    }

    async Task Reset()
    {
        search = null;
        customers = await CustomerService.GetFiltered(null);
    }

    private async Task Delete(int id)
    {
        await CustomerService.Delete(id);
        customers = await CustomerService.GetFiltered(search);
    }
}