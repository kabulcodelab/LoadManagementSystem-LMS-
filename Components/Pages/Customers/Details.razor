@page "/customers/details/{Id:int}"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject CustomerService CustomerService

<h3 class="mb-3">Customer Details</h3>

@if (customer == null)
{
    <div class="alert alert-info">
        Loading...
    </div>
}
else
{
    <!-- CUSTOMER INFO -->
    <div class="card shadow-sm p-4 mb-3">

        <h4>@customer.Name</h4>

        <hr />

        <div class="row">

            <div class="col-md-6">
                <p><b>Customer Code:</b> @customer.CustomerCode</p>
                <p><b>Phone:</b> @customer.PhoneNumber</p>
                <p><b>Email:</b> @customer.Email</p>
            </div>

            <div class="col-md-6">
                <p>
                    <b>Status:</b>
                    <span class="badge @(customer.IsActive ? "bg-success" : "bg-danger")">
                        @(customer.IsActive ? "Active" : "Inactive")
                    </span>
                </p>

                <p><b>Total Loads:</b> @loads?.Count</p>

                <p><b>Total Revenue:</b> @totalRevenue</p>
            </div>

        </div>

    </div>

    <!-- LOAD HISTORY -->
    <div class="card shadow-sm p-4">

        <h5>🚚 Load History</h5>

        @if (loads == null || loads.Count == 0)
        {
            <p>No loads found for this customer.</p>
        }
        else
        {
            <table class="table table-striped">

                <thead class="table-dark">
                    <tr>
                        <th>Load No</th>
                        <th>Tracking</th>
                        <th>Driver</th>
                        <th>Vehicle</th>
                        <th>Status</th>
                        <th>Price</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var l in loads)
                    {
                        <tr>
                            <td>@l.LoadNumber</td>
                            <td>@l.TrackingNumber</td>
                            <td>@l.Driver?.FullName</td>
                            <td>@l.Vehicle?.PlateNumber</td>

                            <td>
                                <span class="@GetStatusClass(l.Status)">
                                    @l.Status
                                </span>
                            </td>

                            <td>@l.Price</td>
                            <td>@l.CreatedDate.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>

            </table>
        }

    </div>

    <!-- BUTTONS -->
    <div class="mt-3">

        <a class="btn btn-warning"
           href="/customers/edit/@customer.Id">
            Edit
        </a>

        <a class="btn btn-secondary ms-2"
           href="/customers">
            Back
        </a>

    </div>
}
@code {

    [Parameter]
    public int Id { get; set; }

    private Customer? customer;
    private List<Load>? loads;
    private decimal totalRevenue;

    protected override async Task OnInitializedAsync()
    {
        customer = await CustomerService.GetById(Id);

        loads = await CustomerService.GetCustomerLoads(Id);

        totalRevenue = loads?.Sum(x => x.Price) ?? 0;
    }

    string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "badge bg-secondary",
            LoadStatus.Assigned => "badge bg-primary",
            LoadStatus.PickedUp => "badge bg-info",
            LoadStatus.InTransit => "badge bg-warning text-dark",
            LoadStatus.Delivered => "badge bg-success",
            LoadStatus.Cancelled => "badge bg-danger",
            _ => "badge bg-dark"
        };
    }
}