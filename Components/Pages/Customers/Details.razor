@page "/customers/details/{Id:int}"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject CustomerService CustomerService
@inject NavigationManager Nav

<PageTitle>Customer Details</PageTitle>

<div class="container-fluid px-3 px-md-4 py-3">

    <div class="page-header">
        <div class="page-title">Customer Details</div>
        <div class="page-subtitle text-muted">Profile & load history</div>
    </div>

    @if (customer == null)
    {
        <div class="lms-card text-center py-5">Loading...</div>
    }
    else
    {
        <!-- CUSTOMER INFO -->
        <div class="lms-card mb-3">

            <h4 class="mb-3">@customer.Name</h4>

            <div class="row g-3">

                <div class="col-md-6">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Customer Code:</strong>
                        <span>@customer.CustomerCode</span>
                    </div>
                    <div class="d-flex justify-content-between py-1">
                        <strong>Phone:</strong>
                        <span>@customer.PhoneNumber</span>
                    </div>
                    <div class="d-flex justify-content-between py-1">
                        <strong>Email:</strong>
                        <span>@customer.Email</span>
                    </div>
                    <div class="d-flex justify-content-between py-1">
                        <strong>Address:</strong>
                        <span>@customer.Address</span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Status:</strong>
                        <span class="badge @(customer.IsActive ? "bg-success" : "bg-danger")">
                            @(customer.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                    <div class="d-flex justify-content-between py-1">
                        <strong>Total Loads:</strong>
                        <span>@(loads?.Count ?? 0)</span>
                    </div>
                    <div class="d-flex justify-content-between py-1">
                        <strong>Total Revenue:</strong>
                        <span>$@(totalRevenue?.ToString("N0") ?? "0")</span>
                    </div>
                </div>

            </div>

        </div>

        <!-- LOAD HISTORY -->
        <div class="lms-card">

            <h5 class="mb-3">🚚 Load History</h5>

            @if (loads == null)
            {
                <p>Loading...</p>
            }
            else if (loads.Count == 0)
            {
                <p class="text-muted">No loads found for this customer.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">

                        <thead>
                            <tr>
                                <th>Load No</th>
                                <th>Tracking</th>
                                <th>Driver</th>
                                <th>Vehicle</th>
                                <th>Status</th>
                                <th>Amount</th>
                                <th>Date</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var l in loads)
                            {
                                <tr>
                                    <td>@l.LoadNumber</td>
                                    <td>@l.TrackingNumber</td>
                                    <td>@l.Driver?.FullName</td>
                                    <td>@l.Vehicle?.PlateNumber</td>

                                    <td>
                                        <span class="badge @GetStatusClass(l.Status)">
                                            @l.Status
                                        </span>
                                    </td>

                                    <td>@(l.Amount?.ToString("N0") ?? "-")</td>
                                    <td>@l.CreatedDate.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }

        </div>

        <!-- ACTION BUTTONS -->
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a class="btn btn-warning w-100 w-md-auto" href="/customers/edit/@customer.Id">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
            <button class="btn btn-secondary w-100 w-md-auto" @onclick="GoBack">
                <i class="bi bi-arrow-left"></i> Back
            </button>
        </div>
    }

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Customer? customer;
    private List<Load>? loads;
    private decimal? totalRevenue;

    protected override async Task OnInitializedAsync()
    {
        customer = await CustomerService.GetById(Id);
        loads = await CustomerService.GetCustomerLoads(Id);
        totalRevenue = loads?.Sum(x => x.Amount ?? 0);
    }

    private void GoBack()
    {
        Nav.NavigateTo("/customers");
    }

    private string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }
}