@page "/customers/edit/{Id:int}"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject CustomerService CustomerService
@inject NavigationManager Navigation

<PageTitle>Edit Customer</PageTitle>

<div class="page-container">

    <div class="page-header">
        <div class="page-title">Edit Customer</div>
        <div class="page-subtitle">Update customer information</div>
    </div>

    @if (customer == null)
    {
        <div class="lms-card">
            Loading...
        </div>
    }
    else
    {
        <div class="lms-card">

            <EditForm Model="@customer" OnValidSubmit="Update">

                <DataAnnotationsValidator />

                <!-- CODE -->
                <div class="mb-3 lms-form">
                    <label>Customer Code</label>
                    <InputText class="form-control"
                               @bind-Value="customer.CustomerCode" />
                </div>

                <!-- NAME -->
                <div class="mb-3 lms-form">
                    <label>Name</label>
                    <InputText class="form-control"
                               @bind-Value="customer.Name" />
                </div>

                <!-- PHONE -->
                <div class="mb-3 lms-form">
                    <label>Phone Number</label>
                    <InputText class="form-control"
                               @bind-Value="customer.PhoneNumber" />
                </div>

                <!-- EMAIL -->
                <div class="mb-3 lms-form">
                    <label>Email</label>
                    <InputText class="form-control"
                               @bind-Value="customer.Email" />
                </div>

                <!-- ADDRESS -->
                <div class="mb-3 lms-form">
                    <label>Address</label>
                    <InputText class="form-control"
                               @bind-Value="customer.Address" />
                </div>

                <!-- ACTIVE -->
                <div class="form-check mb-3">
                    <InputCheckbox class="form-check-input"
                                   @bind-Value="customer.IsActive" />
                    <label class="form-check-label">
                        Active
                    </label>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex gap-2">

                    <button type="submit" class="btn btn-lms-primary">
                        Update
                    </button>

                    <a class="btn btn-secondary" href="/customers">
                        Cancel
                    </a>

                </div>

            </EditForm>

        </div>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Customer? customer;

    protected override async Task OnInitializedAsync()
    {
        customer = await CustomerService.GetById(Id);
    }

    private async Task Update()
    {
        await CustomerService.Update(customer!);
        Navigation.NavigateTo("/customers");
    }
}