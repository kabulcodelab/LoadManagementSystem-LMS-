@page "/customers/create"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms

@inject CustomerService CustomerService
@inject NavigationManager Nav

<PageTitle>Create Customer</PageTitle>

<div class="container-fluid px-3 px-md-4 py-3">

    <div class="page-header mb-4">
        <h2 class="page-title">Create Customer</h2>
        <p class="page-subtitle text-muted">Add a new customer to the system</p>
    </div>

    <div class="lms-card">

        <!-- ====== ALERT (Success/Error) ====== -->
        @if (ShowAlert)
        {
            <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
                <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
                <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
            </div>
        }

        <EditForm Model="@customer" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="row g-3">

                <!-- Customer Code (auto-generated, disabled) -->
                <div class="col-12 col-md-4">
                    <label>Customer Code</label>
                    <InputText class="form-control" @bind-Value="customer.CustomerCode" disabled />
                    <small class="text-muted">Auto‑generated if left empty</small>
                </div>

                <!-- Name (Required) -->
                <div class="col-12 col-md-4">
                    <label>Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="customer.Name" />
                    <ValidationMessage For="@(() => customer.Name)" />
                </div>

                <!-- Phone Number (Required) -->
                <div class="col-12 col-md-4">
                    <label>Phone Number <span class="text-danger">*</span> (10 digits)</label>
                    <InputText class="form-control" @bind-Value="customer.PhoneNumber" />
                    <ValidationMessage For="@(() => customer.PhoneNumber)" />
                </div>

                <!-- Email (Optional) -->
                <div class="col-12 col-md-6">
                    <label>Email</label>
                    <InputText class="form-control" @bind-Value="customer.Email" />
                    <ValidationMessage For="@(() => customer.Email)" />
                </div>

                <!-- Address (Optional) -->
                <div class="col-12 col-md-6">
                    <label>Address</label>
                    <InputText class="form-control" @bind-Value="customer.Address" />
                </div>

                <!-- Is Active (Optional) -->
                <div class="col-12 col-md-4 d-flex align-items-center">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="customer.IsActive" />
                        <label class="form-check-label">Active</label>
                    </div>
                </div>

            </div>

            <div class="d-flex flex-wrap gap-2 mt-4">
                <button type="submit" class="btn btn-add">Save Customer</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>

        </EditForm>

    </div>

</div>

@code {
    private Customer customer = new();

    // ===== Alert Properties =====
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    private async Task HandleValidSubmit()
    {
        try
        {
            // Auto-generate CustomerCode if empty
            if (string.IsNullOrWhiteSpace(customer.CustomerCode))
                customer.CustomerCode = $"CUS-{DateTime.Now:yyyyMMddHHmmss}";

            await CustomerService.Add(customer);

            AlertMessage = $"Customer '{customer.Name}' was added successfully!";
            AlertType = "success";
            ShowAlert = true;
            StateHasChanged();

            await Task.Delay(1000);
            Nav.NavigateTo("/customers");
        }
        catch (Exception ex)
        {
            AlertMessage = $"Error: {ex.Message}";
            AlertType = "danger";
            ShowAlert = true;
            StateHasChanged();
        }
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
    }

    private void Cancel()
    {
        Nav.NavigateTo("/customers");
    }
}