@page "/stops"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components

@inject StopService StopService
@inject NavigationManager Nav

<div class="container-fluid px-3 px-md-4 py-3">

    <!-- HEADER -->
    <div class="row align-items-center mb-4">
        <div class="col-12 col-md-8">
            <h2 class="page-title mb-0">Stops</h2>
            <p class="page-subtitle text-muted mb-0">Manage all pickup and delivery stops</p>
        </div>
        <div class="col-12 col-md-4 text-md-end mt-2 mt-md-0">
            <span class="badge bg-secondary" style="font-size:1rem;">
                Total: @(pagedResult?.TotalCount ?? 0) stops
            </span>
        </div>
    </div>

    <!-- ALERT -->
    @if (ShowAlert)
    {
        <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
            <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
            <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
        </div>
    }

    <!-- SEARCH & FILTER -->
    <div class="lms-card mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Load Number</label>
                <input class="form-control" placeholder="Search by load number..." @bind="searchLoadNumber" @bind:event="oninput" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">Stop Type</label>
                <select class="form-select" @bind="selectedStopType">
                    <option value="">All Types</option>
                    @foreach (StopType type in Enum.GetValues(typeof(StopType)))
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">From Date</label>
                <input type="date" class="form-control" @bind="fromDate" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">To Date</label>
                <input type="date" class="form-control" @bind="toDate" />
            </div>
            <div class="col-12 col-md-1">
                <div class="d-flex gap-2">
                    <button class="btn btn-lms-primary w-100" @onclick="ApplyFilter">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-secondary w-100" @onclick="Reset">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="lms-card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Load #</th>
                        <th>Type</th>
                        <th>Company</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Pickup #</th>
                        <th>Initial Date</th>
                        <th>Final Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pagedResult == null)
                    {
                        <tr><td colspan="11" class="text-center py-4">Loading...</td></tr>
                    }
                    else if (!pagedResult.Items.Any())
                    {
                        <tr><td colspan="11" class="text-center py-4 text-muted">No stops found.</td></tr>
                    }
                    else
                    {
                        @foreach (var stop in pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@stop.Sequence</strong></td>
                                <td>
                                    <a href="/loads/details/@stop.LoadId" class="text-decoration-none">
                                        <code>@stop.Load?.LoadNumber</code>
                                    </a>
                                </td>
                                <td>
                                    <span class="badge @(stop.Type == StopType.Pickup ? "bg-primary" : "bg-success")">
                                        @stop.Type
                                    </span>
                                </td>
                                <td>@stop.Company</td>
                                <td>@stop.Address</td>
                                <td>@stop.City</td>
                                <td>@stop.State</td>
                                <td>@stop.PickupNumber</td>
                                <td>@stop.InitialDateTime?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@stop.FinalDateTime?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-center flex-nowrap">
                                        <!-- View Load -->
                                        <a class="btn btn-sm btn-outline-info"
                                           href="/loads/details/@stop.LoadId"
                                           title="View Load">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <!-- Delete -->
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => ConfirmDelete(stop.Id, stop.Sequence, stop.Load?.LoadNumber)"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @if (pagedResult != null && pagedResult.TotalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3 pt-2 border-top">
                <div class="text-muted small mb-2 mb-md-0">
                    Showing @((pagedResult.CurrentPage - 1) * pagedResult.PageSize + 1) -
                    @Math.Min(pagedResult.CurrentPage * pagedResult.PageSize, pagedResult.TotalCount)
                    of @pagedResult.TotalCount entries
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">«</button>
                        </li>
                        @for (int i = 1; i <= pagedResult.TotalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(i)">@i</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == pagedResult.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">»</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        else if (pagedResult != null && pagedResult.TotalCount > 0)
        {
            <div class="mt-3 pt-2 border-top text-muted small">
                Showing @pagedResult.TotalCount entries
            </div>
        }
    </div>

    <!-- DELETE CONFIRMATION MODAL -->
    @if (DeleteId.HasValue)
    {
        <div class="modal-backdrop fade show" style="display:block;"></div>
        <div class="modal show d-block" tabindex="-1" role="dialog" style="display:block;">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete <strong>Stop #@DeleteSequence</strong> from load <strong>@DeleteLoadNumber</strong>?</p>
                        <p class="text-danger">This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger" @onclick="ExecuteDelete">Yes, Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@code {
    // ===== Fields =====
    private PagedResult<Stop>? pagedResult;
    private int currentPage = 1;
    private const int PageSize = 10;

    // Search / Filter
    private string? searchLoadNumber;
    private StopType? selectedStopType;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    // Delete
    private int? DeleteId;
    private int? DeleteSequence;
    private string? DeleteLoadNumber;

    // ===== Lifecycle =====
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    // ===== Data Loading =====
    private async Task LoadData()
    {
        // Since we need to filter by Load Number, we'll use the service method
        // that gets stops with Load included, then filter in memory.
        // For better performance, you could add a GetPaged method to StopService.
        var allStops = await StopService.GetStopsWithLoad();

        var query = allStops.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchLoadNumber))
        {
            query = query.Where(s => s.Load != null && s.Load.LoadNumber.Contains(searchLoadNumber));
        }

        if (selectedStopType.HasValue)
        {
            query = query.Where(s => s.Type == selectedStopType.Value);
        }

        if (fromDate.HasValue)
        {
            query = query.Where(s => s.CreatedAt >= fromDate.Value);
        }

        if (toDate.HasValue)
        {
            query = query.Where(s => s.CreatedAt <= toDate.Value);
        }

        var totalCount = query.Count();

        var items = query
            .OrderBy(s => s.LoadId)
            .ThenBy(s => s.Sequence)
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

        pagedResult = new PagedResult<Stop>
        {
            Items = items,
            TotalCount = totalCount,
            PageSize = PageSize,
            CurrentPage = currentPage
        };
    }

    // ===== Search / Filter =====
    private async Task ApplyFilter()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task Reset()
    {
        searchLoadNumber = null;
        selectedStopType = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        await LoadData();
    }

    // ===== Pagination =====
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > pagedResult?.TotalPages) return;
        currentPage = page;
        await LoadData();
    }

    // ===== Delete =====
    private void ConfirmDelete(int id, int sequence, string? loadNumber)
    {
        DeleteId = id;
        DeleteSequence = sequence;
        DeleteLoadNumber = loadNumber ?? "Unknown";
        StateHasChanged();
    }

    private void CancelDelete()
    {
        DeleteId = null;
        DeleteSequence = null;
        DeleteLoadNumber = null;
        StateHasChanged();
    }

    private async Task ExecuteDelete()
    {
        if (DeleteId.HasValue)
        {
            try
            {
                await StopService.Delete(DeleteId.Value);
                CancelDelete();
                await LoadData();
                ShowAlertMessage($"Stop #{DeleteSequence} deleted successfully.", isError: false);
            }
            catch (Exception ex)
            {
                ShowAlertMessage($"Error: {ex.Message}", isError: true);
            }
        }
    }

    // ===== Alert Helpers =====
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }
}