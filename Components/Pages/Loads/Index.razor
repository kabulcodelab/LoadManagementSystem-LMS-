@page "/loads"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components

@inject LoadService LoadService
@inject NavigationManager Nav

<div class="container-fluid px-3 px-md-4 py-3">

    <!-- HEADER -->
    <div class="row align-items-center mb-4">
        <div class="col-12 col-md-8">
            <h2 class="page-title mb-0">Loads</h2>
            <p class="page-subtitle text-muted mb-0">Manage all shipments, tracking and delivery status</p>
        </div>
        <div class="col-12 col-md-4 text-md-end mt-2 mt-md-0">
            <a class="btn btn-add w-100 w-md-auto" href="/loads/create">
                <i class="bi bi-plus-circle"></i> Create Loads +
            </a>
        </div>
    </div>

    <!-- ALERT -->
    @if (ShowAlert)
    {
        <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
            <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
            <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
        </div>
    }

    <!-- SEARCH PANEL -->
    <div class="lms-card mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">Search</label>
                <input class="form-control"
                       placeholder="Load, tracking, customer..."
                       @bind="search" @bind:event="oninput" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">From Date</label>
                <input type="date" class="form-control" @bind="fromDate" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">To Date</label>
                <input type="date" class="form-control" @bind="toDate" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">Status</label>
                <select class="form-select" @bind="status">
                    <option value="">All Status</option>
                    @foreach (var s in Enum.GetValues<LoadStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <!-- ===== FIXED PAYMENT FILTER ===== -->
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">Payment</label>
                <select class="form-select" @bind="paymentFilterString">
                    <option value="">All</option>
                    <option value="true">Paid</option>
                    <option value="false">Not Paid</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <div class="d-flex gap-2">
                    <button class="btn btn-lms-primary w-100" @onclick="ApplyFilter">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn btn-secondary w-100" @onclick="Reset">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="lms-card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Load No</th>
                        <th class="d-none d-md-table-cell">Tracking</th>
                        <th>Customer</th>
                        <th>Driver</th>
                        <th class="d-none d-lg-table-cell">Vehicle</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th class="text-center" style="min-width:130px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pagedResult == null)
                    {
                        <tr><td colspan="9" class="text-center py-4">Loading...</td></tr>
                    }
                    else if (!pagedResult.Items.Any())
                    {
                        <tr><td colspan="9" class="text-center py-4 text-muted">No loads found.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in pagedResult.Items)
                        {
                            <tr>
                                <td><code>@item.LoadNumber</code></td>
                                <td class="d-none d-md-table-cell">@item.TrackingNumber</td>
                                <td>@item.Customer?.Name</td>
                                <td>@item.Driver?.FullName</td>
                                <td class="d-none d-lg-table-cell">@item.Vehicle?.PlateNumber</td>
                                <td>
                                    <select class="form-select form-select-sm"
                                            value="@item.Status"
                                            @onchange="(e) => { var newStatus = (LoadStatus)Enum.Parse(typeof(LoadStatus), e.Value.ToString()); if (newStatus != item.Status) { item.Status = newStatus; UpdateStatus(item); } }">
                                        @foreach (var s in Enum.GetValues<LoadStatus>())
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <span class="badge @(item.IsPaid ? "bg-success" : "bg-warning text-dark")"
                                          style="cursor:pointer; font-size:0.9rem;"
                                          @onclick="() => TogglePayment(item)">
                                        @(item.IsPaid ? "Paid" : "Not Paid")
                                    </span>
                                    <br />
                                    <small>@(item.Amount?.ToString("N0") ?? "-")</small>
                                </td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-center flex-nowrap">
                                        <a class="btn btn-sm btn-outline-info" href="/loads/details/@item.Id" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a class="btn btn-sm btn-outline-warning" href="/loads/edit/@item.Id" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(item.Id, item.LoadNumber)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @if (pagedResult != null && pagedResult.TotalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3 pt-2 border-top">
                <div class="text-muted small mb-2 mb-md-0">
                    Showing @((pagedResult.CurrentPage - 1) * pagedResult.PageSize + 1) -
                    @Math.Min(pagedResult.CurrentPage * pagedResult.PageSize, pagedResult.TotalCount)
                    of @pagedResult.TotalCount entries
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @for (int i = 1; i <= pagedResult.TotalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(i)">@i</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == pagedResult.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        else if (pagedResult != null && pagedResult.TotalCount > 0)
        {
            <div class="mt-3 pt-2 border-top text-muted small">
                Showing @pagedResult.TotalCount entries
            </div>
        }
    </div>

    <!-- DELETE CONFIRMATION MODAL -->
    @if (DeleteId.HasValue)
    {
        <div class="modal-backdrop fade show" style="display:block;"></div>
        <div class="modal show d-block" tabindex="-1" role="dialog" style="display:block;">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete load <strong>@DeleteNumber</strong>?</p>
                        <p class="text-danger">This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger" @onclick="ExecuteDelete">Yes, Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@code {
    // ===== Parameters =====
    [Parameter] public string? Message { get; set; }

    // ===== Fields =====
    private PagedResult<Load>? pagedResult;
    private int currentPage = 1;
    private const int PageSize = 10;

    // Search / filter
    private string? search;
    private DateTime? fromDate;
    private DateTime? toDate;
    private LoadStatus? status;
    // ✅ Changed from bool? to string? for proper binding
    private string? paymentFilterString;

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    // Delete confirmation
    private int? DeleteId;
    private string? DeleteNumber;

    // ===== Lifecycle =====
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Message))
        {
            ShowAlertMessage(Message);
        }
    }

    // ===== Data loading =====
    private async Task LoadData()
    {
        // Convert payment filter string to bool?
        bool? isPaid = paymentFilterString switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };

        pagedResult = await LoadService.GetPaged(
            page: currentPage,
            pageSize: PageSize,
            search: search,
            from: fromDate,
            to: toDate,
            status: status,
            isPaid: isPaid
        );
    }

    // ===== Search / Filter =====
    private async Task ApplyFilter()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task Reset()
    {
        search = null;
        fromDate = null;
        toDate = null;
        status = null;
        paymentFilterString = null;  // Reset payment filter
        currentPage = 1;
        await LoadData();
    }

    // ===== Pagination =====
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > pagedResult?.TotalPages) return;
        currentPage = page;
        await LoadData();
    }

    // ===== Inline Status Update =====
    private async Task UpdateStatus(Load item)
    {
        try
        {
            await LoadService.UpdateStatus(item.Id, item.Status);
            ShowAlertMessage($"Status updated to {item.Status}.", isError: false);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error updating status: {ex.Message}", isError: true);
            await LoadData(); // revert to safe state
        }
    }

    // ===== Inline Payment Toggle =====
    private async Task TogglePayment(Load item)
    {
        try
        {
            bool newPaid = !item.IsPaid;
            await LoadService.UpdatePaidStatus(item.Id, newPaid);
            // ✅ Refresh the list to reflect the change
            await LoadData();
            ShowAlertMessage($"Payment status updated to {(newPaid ? "Paid" : "Not Paid")}.", isError: false);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error updating payment status: {ex.Message}", isError: true);
        }
    }

    // ===== Delete =====
    private void ConfirmDelete(int id, string loadNumber)
    {
        DeleteId = id;
        DeleteNumber = loadNumber;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        DeleteId = null;
        DeleteNumber = null;
        StateHasChanged();
    }

    private async Task ExecuteDelete()
    {
        if (DeleteId.HasValue)
        {
            try
            {
                await LoadService.Delete(DeleteId.Value);
                CancelDelete();
                await LoadData();
                ShowAlertMessage($"Load '{DeleteNumber}' was deleted successfully.", isError: false);
            }
            catch (Exception ex)
            {
                ShowAlertMessage($"Error: {ex.Message}", isError: true);
            }
        }
    }

    // ===== Alert helpers =====
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }

    // ===== Utility =====
    private string GetStatusClass(LoadStatus status) // kept for reference if needed elsewhere
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }
}