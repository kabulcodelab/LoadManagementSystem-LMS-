@page "/loads"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject LoadService LoadService

<h3 class="mb-3">Loads Management</h3>

<a class="btn btn-primary mb-3" href="/loads/create">
    + Add Load
</a>

<!-- 🔍 FILTER SECTION -->
<div class="card p-3 mb-3 shadow-sm">

    <div class="row">

        <!-- SEARCH -->
        <div class="col-md-3">
            <input class="form-control"
                   placeholder="Search..."
                   @bind="search" />
        </div>

        <!-- FROM DATE -->
        <div class="col-md-2">
            <input type="date"
                   class="form-control"
                   @bind="fromDate"
                   placeholder="from mm/dd/yy" />
        </div>

        <!-- TO DATE -->
        <div class="col-md-2">
            <input type="date"
                   class="form-control"
                   @bind="toDate"
                   placeholder="to mm/dd/yy" />
        </div>

        <!-- STATUS -->
        <div class="col-md-2">
            <select class="form-select"
                    @bind="status">

                <option value="">All Status</option>

                @foreach (var s in Enum.GetValues<LoadStatus>())
                {
                    <option value="@s">@s</option>
                }

            </select>
        </div>

        <!-- BUTTONS -->
        <div class="col-md-3">

            <button class="btn btn-success me-2" @onclick="ApplyFilter">
                Search
            </button>

            <button class="btn btn-secondary" @onclick="Reset">
                Reset
            </button>

        </div>

    </div>

</div>

<!-- TABLE -->
<table class="table table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>Load No</th>
            <th>Tracking</th>
            <th>Customer</th>
            <th>Driver</th>
            <th>Vehicle</th>
            <th>Status</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (loads == null)
        {
            <tr>
                <td colspan="8">Loading...</td>
            </tr>
        }
        else
        {
            @foreach (var item in loads)
            {
                <tr>

                    <td>@item.LoadNumber</td>
                    <td>@item.TrackingNumber</td>
                    <td>@item.Customer?.Name</td>
                    <td>@item.Driver?.FullName</td>
                    <td>@item.Vehicle?.PlateNumber</td>

                    <!-- ✅ FIXED STATUS (NO HTML STRING PROBLEM) -->
                    <td>
                        <span class="@GetStatusClass(item.Status)">
                            @item.Status
                        </span>
                    </td>

                    <td>@item.Price</td>

                    <td>

                        <a class="btn btn-sm btn-info"
                           href="/loads/details/@item.Id">
                            View
                        </a>

                        <a class="btn btn-sm btn-warning"
                           href="/loads/edit/@item.Id">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                @onclick="() => Delete(item.Id)">
                            Delete
                        </button>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>

@code {

    List<Load>? loads;

    string? search;
    DateTime? fromDate;
    DateTime? toDate;
    LoadStatus? status;

    protected override async Task OnInitializedAsync()
    {
        loads = await LoadService.GetFiltered(null, null, null, null);
    }

    async Task ApplyFilter()
    {
        loads = await LoadService.GetFiltered(search, fromDate, toDate, status);
    }

    async Task Reset()
    {
        search = null;
        fromDate = null;
        toDate = null;
        status = null;

        loads = await LoadService.GetFiltered(null, null, null, null);
    }

    async Task Delete(int id)
    {
        await LoadService.Delete(id);
        loads = await LoadService.GetFiltered(search, fromDate, toDate, status);
    }

    // 🎯 FIXED STATUS DISPLAY (BEST PRACTICE)
    string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "badge bg-secondary",
            LoadStatus.Assigned => "badge bg-primary",
            LoadStatus.PickedUp => "badge bg-info",
            LoadStatus.InTransit => "badge bg-warning text-dark",
            LoadStatus.Delivered => "badge bg-success",
            LoadStatus.Cancelled => "badge bg-danger",
            _ => "badge bg-dark"
        };
    }
}