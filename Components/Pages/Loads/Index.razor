@page "/loads"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject LoadService LoadService

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <div class="page-title">Loads</div>
            <div class="page-subtitle">Manage all shipments, tracking and delivery status</div>
        </div>

        <a class="btn btn-add" href="/loads/create">
            + Add Load
        </a>
    </div>

    <!-- SEARCH PANEL -->
    <div class="search-panel">
        <div class="row g-2">

            <div class="col-12 col-md-3">
                <input class="form-control"
                       placeholder="Search load, tracking, customer..."
                       @bind="search" />
            </div>

            <div class="col-12 col-md-2">
                <input type="date" class="form-control" @bind="fromDate" />
            </div>

            <div class="col-12 col-md-2">
                <input type="date" class="form-control" @bind="toDate" />
            </div>

            <div class="col-12 col-md-2">
                <select class="form-select" @bind="status">
                    <option value="">All Status</option>
                    @foreach (var s in Enum.GetValues<LoadStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-3 d-flex gap-2">
                <button class="btn btn-lms-primary w-100" @onclick="ApplyFilter">
                    Search
                </button>

                <button class="btn btn-secondary w-100" @onclick="Reset">
                    Reset
                </button>
            </div>

        </div>
    </div>

    <!-- TABLE -->
    <div class="table-responsive lms-table">

        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Load No</th>
                    <th>Tracking</th>
                    <th>Customer</th>
                    <th>Driver</th>
                    <th>Vehicle</th>
                    <th>Status</th>
                    <th>Price</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (loads == null)
                {
                    <tr>
                        <td colspan="8" class="text-center p-4">Loading...</td>
                    </tr>
                }
                else if (!loads.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center p-4 text-muted">
                            No loads found
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in loads)
                    {
                        <tr>
                            <td>@item.LoadNumber</td>
                            <td>@item.TrackingNumber</td>
                            <td>@item.Customer?.Name</td>
                            <td>@item.Driver?.FullName</td>
                            <td>@item.Vehicle?.PlateNumber</td>

                            <td>
                                <span class="badge @GetStatusClass(item.Status)">
                                    @item.Status
                                </span>
                            </td>

                            <td>
                                <strong>$@item.Price</strong>
                            </td>

                            <td>
                                <div class="d-flex gap-1 flex-wrap">

                                    <a class="btn btn-sm btn-info" href="/loads/details/@item.Id">
                                        View
                                    </a>

                                    <a class="btn btn-sm btn-warning" href="/loads/edit/@item.Id">
                                        Edit
                                    </a>

                                    <button class="btn btn-sm btn-danger"
                                            @onclick="() => Delete(item.Id)">
                                        Delete
                                    </button>

                                </div>
                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>
    </div>

</div>

@code {

    List<Load>? loads;

    string? search;
    DateTime? fromDate;
    DateTime? toDate;
    LoadStatus? status;

    protected override async Task OnInitializedAsync()
    {
        loads = await LoadService.GetFiltered(null, null, null, null);
    }

    async Task ApplyFilter()
    {
        loads = await LoadService.GetFiltered(search, fromDate, toDate, status);
    }

    async Task Reset()
    {
        search = null;
        fromDate = null;
        toDate = null;
        status = null;

        loads = await LoadService.GetFiltered(null, null, null, null);
    }

    async Task Delete(int id)
    {
        await LoadService.Delete(id);
        loads = await LoadService.GetFiltered(search, fromDate, toDate, status);
    }

    string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }
}