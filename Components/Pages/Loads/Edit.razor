@page "/loads/edit/{Id:int}"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using System.IO

@inject LoadService LoadService
@inject CustomerService CustomerService
@inject DriverService DriverService
@inject VehicleService VehicleService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<div class="container-fluid px-3 px-md-4 py-3">

    <div class="page-header mb-4">
        <h2 class="page-title">Edit Load</h2>
        <p class="page-subtitle text-muted">Update shipment information, stops, and files</p>
    </div>

    <!-- ALERT -->
    @if (ShowAlert)
    {
        <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
            <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
            <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
        </div>
    }

    @if (load == null)
    {
        <div class="lms-card text-center py-5">
            <p>Loading...</p>
        </div>
    }
    else
    {
        <EditForm Model="@load" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "info" ? "active" : "")"
                            type="button" @onclick='() => SetTab("info")'>
                        <i class="bi bi-info-circle"></i> Load Info
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "stops" ? "active" : "")"
                            type="button" @onclick='() => SetTab("stops")'>
                        <i class="bi bi-geo-alt"></i> Stops
                        <span class="badge bg-secondary ms-1">@load.Stops.Count</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "files" ? "active" : "")"
                            type="button" @onclick='() => SetTab("files")'>
                        <i class="bi bi-paperclip"></i> Files
                        <span class="badge bg-secondary ms-1">@load.Documents.Count</span>
                    </button>
                </li>
            </ul>

            <!-- ============================================= -->
            <!-- TAB 1: LOAD INFO                              -->
            <!-- ============================================= -->
            <div class="tab-pane @(activeTab == "info" ? "show active" : "")">
                <div class="lms-card">
                    <div class="row g-3">

                        <!-- Load Number (read-only) -->
                        <div class="col-12 col-md-4">
                            <label>Load Number</label>
                            <InputText class="form-control" @bind-Value="load.LoadNumber" disabled />
                            <small class="text-muted">Auto‑generated, cannot be changed</small>
                        </div>

                        <!-- Tracking Number -->
                        <div class="col-12 col-md-4">
                            <label>Tracking Number</label>
                            <InputText class="form-control" @bind-Value="load.TrackingNumber" />
                        </div>

                        <!-- Load Type -->
                        <div class="col-12 col-md-4">
                            <label>Load Type</label>
                            <InputSelect class="form-select" @bind-Value="load.Type">
                                @foreach (LoadType type in Enum.GetValues(typeof(LoadType)))
                                {
                                    <option value="@type">@type.ToString()</option>
                                }
                            </InputSelect>
                        </div>

                        <!-- Customer -->
                        <div class="col-12 col-md-4">
                            <label>Customer *</label>
                            <InputSelect class="form-select" @bind-Value="load.CustomerId">
                                <option value="0">Select Customer</option>
                                @foreach (var c in customers)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => load.CustomerId)" />
                        </div>

                        <!-- Driver -->
                        <div class="col-12 col-md-4">
                            <label>Driver *</label>
                            <InputSelect class="form-select" @bind-Value="load.DriverId">
                                <option value="0">Select Driver</option>
                                @foreach (var d in drivers)
                                {
                                    <option value="@d.Id">@d.FullName</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => load.DriverId)" />
                        </div>

                        <!-- Vehicle -->
                        <div class="col-12 col-md-4">
                            <label>Vehicle *</label>
                            <InputSelect class="form-select" @bind-Value="load.VehicleId">
                                <option value="0">Select Vehicle</option>
                                @foreach (var v in vehicles)
                                {
                                    <option value="@v.Id">@v.PlateNumber - @v.Model</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => load.VehicleId)" />
                        </div>

                        <!-- Status -->
                        <div class="col-12 col-md-4">
                            <label>Status</label>
                            <InputSelect class="form-select" @bind-Value="load.Status">
                                @foreach (LoadStatus status in Enum.GetValues(typeof(LoadStatus)))
                                {
                                    <option value="@status">@status.ToString()</option>
                                }
                            </InputSelect>
                        </div>

                        <!-- Pickup Date -->
                        <div class="col-12 col-md-4">
                            <label>Pickup Date</label>
                            <InputDate class="form-control" @bind-Value="load.PickupDate" />
                        </div>

                        <!-- Delivery Date -->
                        <div class="col-12 col-md-4">
                            <label>Delivery Date</label>
                            <InputDate class="form-control" @bind-Value="load.DeliveryDate" />
                        </div>

                        <!-- Amount -->
                        <div class="col-12 col-md-4">
                            <label>Amount</label>
                            <InputNumber class="form-control" @bind-Value="load.Amount" step="0.01" />
                        </div>

                        <!-- Is Paid -->
                        <div class="col-12 col-md-4 d-flex align-items-center">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="load.IsPaid" />
                                <label class="form-check-label">Paid</label>
                            </div>
                        </div>

                        <!-- Remarks -->
                        <div class="col-12">
                            <label>Remarks</label>
                            <InputTextArea class="form-control" @bind-Value="load.Remarks" rows="3" placeholder="Any additional notes..." />
                        </div>

                        <!-- System fields (read-only) -->
                        <div class="col-12">
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <small class="text-muted">
                                        <strong>Created:</strong> @load.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                                    </small>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">
                                        <strong>Last Updated:</strong> @(load.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                                    </small>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ============================================= -->
            <!-- TAB 2: STOPS (safe deletion by object)       -->
            <!-- ============================================= -->
            <div class="tab-pane @(activeTab == "stops" ? "show active" : "")">
                <div class="lms-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Stops</h5>
                        <button type="button" class="btn btn-sm btn-success" @onclick="AddStop">
                            <i class="bi bi-plus-circle"></i> Add Stops +
                        </button>
                    </div>

                    @if (load.Stops.Count == 0)
                    {
                        <p class="text-muted">No stops added yet. Click "Add Stops +" to start.</p>
                    }
                    else
                    {
                        @for (int i = 0; i < load.Stops.Count; i++)
                        {
                            var stop = load.Stops[i];
                            <div class="border rounded p-3 mb-3 position-relative">

                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="mb-0">Stop @(i + 1)</h6>
                                    <button type="button" class="btn-close"
                                            @onclick='() => RemoveStop(stop)'
                                            title="Remove this stop"
                                            disabled="@(load.Stops.Count == 1)">
                                    </button>
                                </div>

                                <div class="row g-3">
                                    <!-- Type -->
                                    <div class="col-12 col-md-3">
                                        <label>Type</label>
                                        <InputSelect class="form-select" @bind-Value="stop.Type">
                                            <option value="@StopType.Pickup">Pickup</option>
                                            <option value="@StopType.Delivery">Delivery</option>
                                        </InputSelect>
                                    </div>

                                    <!-- Company -->
                                    <div class="col-12 col-md-3">
                                        <label>Company</label>
                                        <InputText class="form-control" @bind-Value="stop.Company" placeholder="Company name" />
                                    </div>

                                    <!-- Initial Date/Time -->
                                    <div class="col-12 col-md-3">
                                        <label>Initial Date/Time</label>
                                        <InputDate class="form-control" @bind-Value="stop.InitialDateTime" />
                                    </div>

                                    <!-- Final Date/Time -->
                                    <div class="col-12 col-md-3">
                                        <label>Final Date/Time</label>
                                        <InputDate class="form-control" @bind-Value="stop.FinalDateTime" />
                                    </div>

                                    <!-- Address -->
                                    <div class="col-12 col-md-6">
                                        <label>Address</label>
                                        <InputText class="form-control" @bind-Value="stop.Address" placeholder="Street address" />
                                    </div>

                                    <!-- City -->
                                    <div class="col-12 col-md-2">
                                        <label>City</label>
                                        <InputText class="form-control" @bind-Value="stop.City" placeholder="City" />
                                    </div>

                                    <!-- State -->
                                    <div class="col-12 col-md-2">
                                        <label>State</label>
                                        <InputText class="form-control" @bind-Value="stop.State" placeholder="State" />
                                    </div>

                                    <!-- Zip Code -->
                                    <div class="col-12 col-md-2">
                                        <label>Zip Code</label>
                                        <InputText class="form-control" @bind-Value="stop.ZipCode" placeholder="Zip" />
                                    </div>

                                    <!-- Pickup Number -->
                                    <div class="col-12 col-md-3">
                                        <label>Pickup Number</label>
                                        <InputText class="form-control" @bind-Value="stop.PickupNumber" placeholder="Ref #" />
                                    </div>

                                    <!-- Loaded Miles -->
                                    <div class="col-12 col-md-3">
                                        <label>Loaded Miles</label>
                                        <InputNumber class="form-control" @bind-Value="stop.LoadedMiles" step="0.1" />
                                    </div>

                                    <!-- Empty Miles -->
                                    <div class="col-12 col-md-3">
                                        <label>Empty Miles</label>
                                        <InputNumber class="form-control" @bind-Value="stop.EmptyMiles" step="0.1" />
                                    </div>

                                    <!-- Remarks -->
                                    <div class="col-12">
                                        <label>Remarks</label>
                                        <InputText class="form-control" @bind-Value="stop.Remarks" placeholder="Any notes for this stop" />
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- ============================================= -->
            <!-- TAB 3: FILES (with document type selection)  -->
            <!-- ============================================= -->
            <div class="tab-pane @(activeTab == "files" ? "show active" : "")">
                <div class="lms-card">
                    <h5 class="mb-3">Upload Documents</h5>

                    <!-- ========================================== -->
                    <!-- 1. Rate Confirmation                       -->
                    <!-- ========================================== -->
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">Rate Confirmation</h6>
                            <InputFile class="form-control w-auto"
                                       OnChange="@((e) => HandleFileUpload(e, DocumentType.RateConfirmation))"
                                       multiple />
                        </div>
                    </div>

                    <!-- ========================================== -->
                    <!-- 2. Bill of Lading                          -->
                    <!-- ========================================== -->
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">Bill of Lading</h6>
                            <InputFile class="form-control w-auto"
                                       OnChange="@((e) => HandleFileUpload(e, DocumentType.BillOfLading))"
                                       multiple />
                        </div>
                    </div>

                    <!-- ========================================== -->
                    <!-- 3. Other                                   -->
                    <!-- ========================================== -->
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">Other</h6>
                            <InputFile class="form-control w-auto"
                                       OnChange="@((e) => HandleFileUpload(e, DocumentType.Others))"
                                       multiple />
                        </div>
                    </div>

                    <!-- ========================================== -->
                    <!-- Uploaded Files Table                       -->
                    <!-- ========================================== -->
                    @if (load.Documents.Count > 0)
                    {
                        <div class="table-responsive mt-3">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>File Name</th>
                                        <th>Type</th>
                                        <th>Size</th>
                                        <th>Uploaded</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in load.Documents)
                                    {
                                        <tr>
                                            <td>@doc.FileName</td>
                                            <td>
                                                <span class="badge @GetDocTypeBadge(doc.FileType)">
                                                    @GetDocumentTypeDisplayName(doc.FileType)
                                                </span>
                                            </td>
                                            <td>@(doc.FileSize?.ToString("N0") ?? "-") bytes</td>
                                            <td>@doc.UploadedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <!-- View Button -->
                                                    @if (doc.FileContent != null && doc.FileContent.Length > 0)
                                                    {
                                                        <button class="btn btn-sm btn-outline-success"
                                                                @onclick='() => ViewFile(doc)'>
                                                            <i class="bi bi-eye"></i>
                                                        </button>
                                                    }
                                                    else if (!string.IsNullOrEmpty(doc.FilePath))
                                                    {
                                                        <a class="btn btn-sm btn-outline-success"
                                                           href="@doc.FilePath" target="_blank">
                                                            <i class="bi bi-eye"></i>
                                                        </a>
                                                    }
                                                    <!-- Delete Button -->
                                                    <button type="button" class="btn btn-sm btn-danger"
                                                            @onclick='() => RemoveFile(doc)'>
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mt-3">No files uploaded yet.</p>
                    }
                </div>
            </div>

            <!-- ============================================= -->
            <!-- BUTTONS                                      -->
            <!-- ============================================= -->
            <div class="d-flex flex-wrap gap-2 mt-4">
                <button type="submit" class="btn btn-add w-100 w-md-auto">
                    <i class="bi bi-save"></i> Update Load
                </button>
                <button type="button" class="btn btn-secondary w-100 w-md-auto" @onclick="Cancel">
                    <i class="bi bi-x-circle"></i> Cancel
                </button>
            </div>

        </EditForm>
    }
</div>

<!-- ============================================= -->
<!-- JavaScript function to view Base64 files      -->
<!-- (Same as in Create page)                     -->
<!-- ============================================= -->
<script>
    window.viewBase64File = function (base64String, contentType, fileName) {
        try {
            const byteCharacters = atob(base64String);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray], { type: contentType });
            const url = URL.createObjectURL(blob);
            window.open(url, '_blank');
            // Free memory after 1 minute
            setTimeout(() => URL.revokeObjectURL(url), 60000);
        } catch (error) {
            console.error('Error viewing file:', error);
            alert('Could not open the file. Please try downloading it.');
        }
    };
</script>

@code {
    [Parameter] public int Id { get; set; }

    // ===== Fields =====
    private Load? load;
    private List<Customer> customers = new();
    private List<Driver> drivers = new();
    private List<Vehicle> vehicles = new();

    private string activeTab = "info";

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    // ===== Lifecycle =====
    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();

        load = await LoadService.GetById(Id);
        if (load == null)
        {
            // Handle not found if needed
        }
    }

    private async Task LoadLookupData()
    {
        customers = await CustomerService.GetAll();
        drivers = await DriverService.GetAll();
        vehicles = await VehicleService.GetAll();
    }

    // ===== Tab Management =====
    private void SetTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
    }

    // ===== Stop Management =====
    private void AddStop()
    {
        load?.Stops.Add(new Stop { Type = StopType.Delivery });
        StateHasChanged();
    }

    private void RemoveStop(Stop stop)
    {
        if (load != null && load.Stops.Count > 1 && load.Stops.Contains(stop))
        {
            load.Stops.Remove(stop);
            StateHasChanged();
        }
    }

    // ===== File Management =====
    private async Task HandleFileUpload(InputFileChangeEventArgs e, DocumentType fileType)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            using var memoryStream = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(memoryStream);

            var document = new Document
            {
                FileName = file.Name,
                FileSize = (int)file.Size,
                FileContent = memoryStream.ToArray(),
                UploadedAt = DateTime.Now,
                ContentType = file.ContentType,
                FileType = fileType
            };

            load?.Documents.Add(document);
        }

        StateHasChanged();
    }

    private void RemoveFile(Document doc)
    {
        load?.Documents.Remove(doc);
        StateHasChanged();
    }

    // ===== Helper: Get MIME type from file name =====
    private string GetMimeType(string fileName)
    {
        var ext = Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "application/pdf",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".gif" => "image/gif",
            ".bmp" => "image/bmp",
            ".webp" => "image/webp",
            ".doc" => "application/msword",
            ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            ".xls" => "application/vnd.ms-excel",
            ".xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            ".ppt" => "application/vnd.ms-powerpoint",
            ".pptx" => "application/vnd.openxmlformats-officedocument.presentationml.presentation",
            ".txt" => "text/plain",
            ".csv" => "text/csv",
            ".zip" => "application/zip",
            ".rar" => "application/x-rar-compressed",
            ".7z" => "application/x-7z-compressed",
            ".xml" => "application/xml",
            ".json" => "application/json",
            _ => "application/octet-stream"
        };
    }

    // ===== View File (using JavaScript) =====
    private async Task ViewFile(Document doc)
    {
        if (doc.FileContent == null || doc.FileContent.Length == 0)
            return;

        try
        {
            var base64 = Convert.ToBase64String(doc.FileContent);
            var mimeType = GetMimeType(doc.FileName);
            await JSRuntime.InvokeVoidAsync("viewBase64File", base64, mimeType, doc.FileName);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error viewing file: {ex.Message}", isError: true);
        }
    }

    // ===== Helper methods for DocumentType display =====
    private string GetDocumentTypeDisplayName(DocumentType type)
    {
        return type switch
        {
            DocumentType.RateConfirmation => "Rate Confirmation",
            DocumentType.BillOfLading => "Bill of Lading",
            DocumentType.Others => "Other",
            _ => type.ToString()
        };
    }

    private string GetDocTypeBadge(DocumentType type)
    {
        return type switch
        {
            DocumentType.RateConfirmation => "bg-primary",
            DocumentType.BillOfLading => "bg-success",
            DocumentType.Others => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    // ===== Save =====
    private async Task HandleValidSubmit()
    {
        try
        {
            await LoadService.Update(load!);
            ShowAlertMessage($"Load '{load!.LoadNumber}' updated successfully!", isError: false);
            await Task.Delay(1000);
            Nav.NavigateTo("/loads");
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    private void Cancel()
    {
        Nav.NavigateTo("/loads");
    }

    // ===== Alert helpers =====
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }
}