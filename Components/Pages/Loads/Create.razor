@page "/loads/create"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject LoadService LoadService
@inject CustomerService CustomerService
@inject DriverService DriverService
@inject VehicleService VehicleService
@inject NavigationManager Navigation

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <div class="page-title">Create Load</div>
        <div class="page-subtitle">Add a new shipment with driver, vehicle and customer</div>
    </div>

    <EditForm Model="load" OnValidSubmit="Save">
        <DataAnnotationsValidator />

        <div class="lms-card">

            <!-- LOAD INFO -->
            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <label>Load Number</label>
                    <InputText class="form-control" @bind-Value="load.LoadNumber" />
                </div>

                <div class="col-12 col-md-6">
                    <label>Tracking Number</label>
                    <InputText class="form-control" @bind-Value="load.TrackingNumber" />
                </div>

            </div>

            <hr class="my-4" />

            <!-- RELATIONS -->
            <div class="row g-3">

                <div class="col-12 col-md-4">
                    <label>Customer</label>
                    <InputSelect class="form-select" @bind-Value="load.CustomerId">
                        <option value="0">Select Customer</option>
                        @foreach (var c in customers)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-12 col-md-4">
                    <label>Driver</label>
                    <InputSelect class="form-select" @bind-Value="load.DriverId">
                        <option value="0">Select Driver</option>
                        @foreach (var d in drivers)
                        {
                            <option value="@d.Id">@d.FullName</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-12 col-md-4">
                    <label>Vehicle</label>
                    <InputSelect class="form-select" @bind-Value="load.VehicleId">
                        <option value="0">Select Vehicle</option>
                        @foreach (var v in vehicles)
                        {
                            <option value="@v.Id">@v.PlateNumber</option>
                        }
                    </InputSelect>
                </div>

            </div>

            <hr class="my-4" />

            <!-- LOCATIONS -->
            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <label>Pickup Location</label>
                    <InputText class="form-control" @bind-Value="load.PickupLocation" />
                </div>

                <div class="col-12 col-md-6">
                    <label>Delivery Location</label>
                    <InputText class="form-control" @bind-Value="load.DeliveryLocation" />
                </div>

            </div>

            <hr class="my-4" />

            <!-- PRICE -->
            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <label>Weight</label>
                    <InputNumber class="form-control" @bind-Value="load.Weight" />
                </div>

                <div class="col-12 col-md-6">
                    <label>Price</label>
                    <InputNumber class="form-control" @bind-Value="load.Price" />
                </div>

            </div>

            <hr class="my-4" />

            <!-- DATES -->
            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <label>Pickup Date</label>
                    <InputDate class="form-control" @bind-Value="load.PickupDate" />
                </div>

                <div class="col-12 col-md-6">
                    <label>Delivery Date</label>
                    <InputDate class="form-control" @bind-Value="load.DeliveryDate" />
                </div>

            </div>

            <hr class="my-4" />

            <!-- REMARKS -->
            <div class="mb-3">
                <label>Remarks</label>
                <InputTextArea class="form-control" @bind-Value="load.Remarks" />
            </div>

            <!-- ACTIONS -->
            <div class="d-flex flex-wrap gap-2 mt-3">

                <button type="submit" class="btn btn-add">
                    Save Load
                </button>

                <a class="btn btn-secondary" href="/loads">
                    Cancel
                </a>

            </div>

        </div>

    </EditForm>

</div>

@code {

    private Load load = new();

    private List<Customer> customers = new();
    private List<Driver> drivers = new();
    private List<Vehicle> vehicles = new();

    protected override async Task OnInitializedAsync()
    {
        customers = await CustomerService.GetAll();
        drivers = await DriverService.GetAll();
        vehicles = await VehicleService.GetAll();

        load.PickupDate = DateTime.Today;
        load.Status = LoadStatus.Pending;
    }

    private async Task Save()
    {
        await LoadService.Add(load);
        Navigation.NavigateTo("/loads");
    }
}