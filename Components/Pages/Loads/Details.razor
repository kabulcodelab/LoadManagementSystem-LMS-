@page "/loads/details/{Id:int}"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using System.IO

@inject LoadService LoadService
@inject DocumentService DocumentService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<div class="container-fluid px-3 px-md-4 py-3">

    @if (load == null)
    {
        <div class="lms-card text-center py-5">
            <p>Loading...</p>
        </div>
    }
    else
    {
        <!-- HEADER -->
        <div class="row align-items-center mb-4">
            <div class="col-12 col-md-8">
                <h2 class="page-title mb-0">Load #@load.LoadNumber</h2>
                <p class="page-subtitle text-muted mb-0">
                    <i class="bi bi-upc-scan"></i> Tracking: @load.TrackingNumber
                </p>
            </div>
            <div class="col-12 col-md-4 text-md-end mt-2 mt-md-0">
                <span class="badge @GetStatusClass(load.Status)" style="font-size:1rem; padding:0.6rem 1.2rem;">
                    @load.Status
                </span>
            </div>
        </div>

        <!-- ALERT -->
        @if (ShowAlert)
        {
            <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
                <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
                <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
            </div>
        }

        <!-- ============================================= -->
        <!-- SECTION 1: LOAD INFORMATION                   -->
        <!-- ============================================= -->
        <div class="lms-card">
            <h5 class="border-bottom pb-2 mb-3">
                <i class="bi bi-info-circle"></i> Load Information
            </h5>
            <div class="row g-3">

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Load Number:</strong>
                        <span><code>@load.LoadNumber</code></span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Tracking Number:</strong>
                        <span>@load.TrackingNumber</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Load Type:</strong>
                        <span>@load.Type</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Customer:</strong>
                        <span>@load.Customer?.Name</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Driver:</strong>
                        <span>@load.Driver?.FullName</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Vehicle:</strong>
                        <span>@load.Vehicle?.PlateNumber</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Pickup Date:</strong>
                        <span>@load.PickupDate?.ToShortDateString()</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Delivery Date:</strong>
                        <span>@(load.DeliveryDate?.ToShortDateString() ?? "-")</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Amount:</strong>
                        <span>@(load.Amount?.ToString("N0") ?? "-")</span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Payment Status:</strong>
                        <span>
                            <span class="badge @(load.IsPaid ? "bg-success" : "bg-warning text-dark")">
                                @(load.IsPaid ? "Paid" : "Unpaid")
                            </span>
                        </span>
                    </div>
                </div>

                <div class="col-12">
                    <div class="d-flex justify-content-between py-1">
                        <strong>Remarks:</strong>
                        <span class="text-wrap">@(string.IsNullOrEmpty(load.Remarks) ? "-" : load.Remarks)</span>
                    </div>
                </div>

                <div class="col-12">
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">
                                <strong>Created:</strong> @load.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                            </small>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">
                                <strong>Last Updated:</strong> @(load.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                            </small>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- ============================================= -->
        <!-- SECTION 2: STOPS                              -->
        <!-- ============================================= -->
        <div class="lms-card mt-3">
            <h5 class="border-bottom pb-2 mb-3">
                <i class="bi bi-geo-alt"></i> Stops
                <span class="badge bg-secondary ms-1">@load.Stops.Count</span>
            </h5>

            @if (load.Stops.Count == 0)
            {
                <p class="text-muted">No stops defined for this load.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Type</th>
                                <th>Company</th>
                                <th>Address</th>
                                <th>City</th>
                                <th>State</th>
                                <th>Zip</th>
                                <th>Initial Date/Time</th>
                                <th>Final Date/Time</th>
                                <th>Loaded Miles</th>
                                <th>Empty Miles</th>
                                <th>Pickup #</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < load.Stops.Count; i++)
                            {
                                var stop = load.Stops[i];
                                <tr>
                                    <td><strong>@(i + 1)</strong></td>
                                    <td>
                                        <span class="badge @(stop.Type == StopType.Pickup ? "bg-primary" : "bg-success")">
                                            @stop.Type
                                        </span>
                                    </td>
                                    <td>@stop.Company</td>
                                    <td>@stop.Address</td>
                                    <td>@stop.City</td>
                                    <td>@stop.State</td>
                                    <td>@stop.ZipCode</td>
                                    <td>@stop.InitialDateTime?.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@stop.FinalDateTime?.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@stop.LoadedMiles?.ToString("N1")</td>
                                    <td>@stop.EmptyMiles?.ToString("N1")</td>
                                    <td>@stop.PickupNumber</td>
                                    <td>@stop.Remarks</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- ============================================= -->
        <!-- SECTION 3: FILES (with Download button)      -->
        <!-- ============================================= -->
        <div class="lms-card mt-3">
            <h5 class="border-bottom pb-2 mb-3">
                <i class="bi bi-paperclip"></i> Files
                <span class="badge bg-secondary ms-1">@(documents?.Count ?? 0)</span>
            </h5>

            @if (documents == null || documents.Count == 0)
            {
                <p class="text-muted">No files uploaded for this load.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>File Name</th>
                                <th>Type</th>
                                <th>Size</th>
                                <th>Uploaded At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in documents)
                            {
                                <tr>
                                    <td><i class="bi bi-file-earmark"></i> @doc.FileName</td>
                                    <td>
                                        <span class="badge @GetDocTypeBadge(doc.FileType)">
                                            @GetDocumentTypeDisplayName(doc.FileType)
                                        </span>
                                    </td>
                                    <td>@(doc.FileSize?.ToString("N0") ?? "-") bytes</td>
                                    <td>@doc.UploadedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <!-- View Button -->
                                            <button class="btn btn-sm btn-outline-primary" @onclick='() => ViewFile(doc.Id)' title="View">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <!-- Download Button -->
                                            <button class="btn btn-sm btn-outline-success" @onclick='() => DownloadFile(doc.Id)' title="Download">
                                                <i class="bi bi-download"></i>
                                            </button>
                                            <!-- Delete Button -->
                                            <button class="btn btn-sm btn-outline-danger" @onclick='() => DeleteFile(doc.Id, doc.FileName)' title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- ============================================= -->
        <!-- ACTION BUTTONS                               -->
        <!-- ============================================= -->
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a class="btn btn-warning w-100 w-md-auto" href="/loads/edit/@load.Id">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
            <button class="btn btn-secondary w-100 w-md-auto" @onclick="GoBack">
                <i class="bi bi-arrow-left"></i> Back to List
            </button>
        </div>
    }
</div>

<!-- ============================================= -->
<!-- JavaScript functions for View & Download      -->
<!-- ============================================= -->
<script>
    // View file in new tab
    window.viewBase64File = function (base64String, contentType, fileName) {
        try {
            const byteCharacters = atob(base64String);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray], { type: contentType });
            const url = URL.createObjectURL(blob);
            window.open(url, '_blank');
            setTimeout(() => URL.revokeObjectURL(url), 60000);
        } catch (error) {
            console.error('Error viewing file:', error);
            alert('Could not open the file. Please try downloading it.');
        }
    };

    // Download file directly
    window.downloadBase64File = function (base64String, fileName) {
        try {
            const byteCharacters = atob(base64String);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray]);
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            setTimeout(() => URL.revokeObjectURL(url), 60000);
        } catch (error) {
            console.error('Error downloading file:', error);
            alert('Could not download the file. Please try again.');
        }
    };
</script>

@code {
    [Parameter] public int Id { get; set; }

    private Load? load;
    private List<Document>? documents;

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    // ===== Lifecycle =====
    protected override async Task OnInitializedAsync()
    {
        load = await LoadService.GetById(Id);
        if (load != null)
        {
            documents = await DocumentService.GetByLoad(Id);
        }
    }

    // ===== Go Back =====
    private void GoBack()
    {
        Nav.NavigateTo("/loads");
    }

    // ===== View File =====
    private async Task ViewFile(int docId)
    {
        try
        {
            var doc = await DocumentService.GetDocumentWithContent(docId);
            if (doc == null || doc.FileContent == null || doc.FileContent.Length == 0)
            {
                ShowAlertMessage("File content is empty or unavailable.", isError: true);
                return;
            }
            var base64 = Convert.ToBase64String(doc.FileContent);
            var mimeType = GetMimeType(doc.FileName);
            await JSRuntime.InvokeVoidAsync("viewBase64File", base64, mimeType, doc.FileName);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error viewing file: {ex.Message}", isError: true);
        }
    }

    // ===== Download File =====
    private async Task DownloadFile(int docId)
    {
        try
        {
            var doc = await DocumentService.GetDocumentWithContent(docId);
            if (doc == null || doc.FileContent == null || doc.FileContent.Length == 0)
            {
                ShowAlertMessage("File content is empty or unavailable.", isError: true);
                return;
            }
            var base64 = Convert.ToBase64String(doc.FileContent);
            await JSRuntime.InvokeVoidAsync("downloadBase64File", base64, doc.FileName);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error downloading file: {ex.Message}", isError: true);
        }
    }

    // ===== Delete File =====
    private async Task DeleteFile(int docId, string fileName)
    {
        try
        {
            await DocumentService.Delete(docId);
            if (load != null)
            {
                documents = await DocumentService.GetByLoad(Id);
            }
            ShowAlertMessage($"File '{fileName}' deleted successfully.", isError: false);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error deleting file: {ex.Message}", isError: true);
        }
    }

    // ===== Helper: Get MIME type from file name =====
    private string GetMimeType(string fileName)
    {
        var ext = Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "application/pdf",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".gif" => "image/gif",
            ".bmp" => "image/bmp",
            ".webp" => "image/webp",
            ".doc" => "application/msword",
            ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            ".xls" => "application/vnd.ms-excel",
            ".xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            ".ppt" => "application/vnd.ms-powerpoint",
            ".pptx" => "application/vnd.openxmlformats-officedocument.presentationml.presentation",
            ".txt" => "text/plain",
            ".csv" => "text/csv",
            ".zip" => "application/zip",
            ".rar" => "application/x-rar-compressed",
            ".7z" => "application/x-7z-compressed",
            ".xml" => "application/xml",
            ".json" => "application/json",
            _ => "application/octet-stream"
        };
    }

    // ===== Helper methods for DocumentType display =====
    private string GetDocumentTypeDisplayName(DocumentType type)
    {
        return type switch
        {
            DocumentType.RateConfirmation => "Rate Confirmation",
            DocumentType.BillOfLading => "Bill of Lading",
            DocumentType.Others => "Other",
            _ => type.ToString()
        };
    }

    private string GetDocTypeBadge(DocumentType type)
    {
        return type switch
        {
            DocumentType.RateConfirmation => "bg-primary",
            DocumentType.BillOfLading => "bg-success",
            DocumentType.Others => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    // ===== Status badge for Load =====
    private string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }

    // ===== Alert helpers =====
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(3000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }
}