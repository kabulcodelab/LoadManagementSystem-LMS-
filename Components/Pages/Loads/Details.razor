@page "/loads/details/{Id:int}"
@attribute [Authorize]
@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject LoadService LoadService
@inject DocumentService DocumentService

<div class="page-container">

    @if (load == null)
    {
        <div class="lms-card">Loading...</div>
    }
    else
    {
        <!-- HEADER -->
        <div class="page-header d-flex justify-content-between align-items-center">

            <div>
                <div class="page-title">
                    Load #@load.LoadNumber
                </div>
                <div class="page-subtitle">
                    Tracking: @load.TrackingNumber
                </div>
            </div>

            <span class="badge @GetStatusClass(load.Status)">
                @load.Status
            </span>

        </div>

        <!-- MAIN INFO -->
        <div class="lms-card">

            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <p><b>Customer:</b> @load.Customer?.Name</p>
                    <p><b>Driver:</b> @load.Driver?.FullName</p>
                    <p><b>Vehicle:</b> @load.Vehicle?.PlateNumber</p>
                </div>

                <div class="col-12 col-md-6">
                    <p><b>Weight:</b> @load.Weight</p>
                    <p><b>Price:</b> @load.Price</p>
                    <p><b>Pickup:</b> @load.PickupDate.ToShortDateString()</p>
                    <p><b>Delivery:</b> @(load.DeliveryDate?.ToShortDateString() ?? "-")</p>
                </div>

            </div>

        </div>

        <!-- LOCATIONS -->
        <div class="lms-card mt-3">

            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <h6 class="fw-bold">Pickup Location</h6>
                    <p>@load.PickupLocation</p>
                </div>

                <div class="col-12 col-md-6">
                    <h6 class="fw-bold">Delivery Location</h6>
                    <p>@load.DeliveryLocation</p>
                </div>

            </div>

        </div>

        <!-- REMARKS -->
        <div class="lms-card mt-3">

            <h6 class="fw-bold">Remarks</h6>
            <p class="mb-0">@load.Remarks</p>

        </div>

        <!-- DOCUMENTS -->
        <div class="lms-card mt-3">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Documents</h5>
            </div>

            <InputFile OnChange="UploadFile" class="form-control mb-3" />

            @if (documents == null)
            {
                <p>Loading files...</p>
            }
            else if (documents.Count == 0)
            {
                <p>No documents uploaded.</p>
            }
            else
            {
                <ul class="list-group">

                    @foreach (var doc in documents)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">

                            <span>@doc.FileName</span>

                            <div class="d-flex gap-2">

                                <a class="btn btn-sm btn-success"
                                   href="@doc.FilePath"
                                   target="_blank">
                                    Download
                                </a>

                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => DeleteDoc(doc.Id)">
                                    Delete
                                </button>

                            </div>

                        </li>
                    }

                </ul>
            }

        </div>

        <!-- ACTION BUTTONS -->
        <div class="d-flex flex-wrap gap-2 mt-3">

            <a class="btn btn-warning" href="/loads/edit/@load.Id">
                Edit
            </a>

            <a class="btn btn-secondary" href="/loads">
                Back
            </a>

        </div>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Load? load;
    private List<Document>? documents;

    protected override async Task OnInitializedAsync()
    {
        load = await LoadService.GetById(Id);
        documents = await DocumentService.GetByLoad(Id);
    }

    string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }

    private async Task UploadFile(InputFileChangeEventArgs e)
    {
        var file = e.File;

        using var stream = file.OpenReadStream(10 * 1024 * 1024);

        var formFile = new FormFile(stream, 0, file.Size, file.Name, file.Name);

        await DocumentService.Upload(formFile, Id);

        documents = await DocumentService.GetByLoad(Id);
    }

    private async Task DeleteDoc(int docId)
    {
        await DocumentService.Delete(docId);
        documents = await DocumentService.GetByLoad(Id);
    }
}