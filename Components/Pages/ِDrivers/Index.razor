@page "/drivers"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject DriverService DriverService

<div class="page-container">

    <!-- Header -->
    <div class="page-header d-flex justify-content-between align-items-center">

        <div>
            <h2 class="page-title">Drivers Management</h2>
            <div class="page-subtitle">
                Manage all drivers and their transportation history
            </div>
        </div>

        <a class="btn btn-add" href="/drivers/create">
            + Add Driver
        </a>

    </div>

    <!-- Search Card -->
    <div class="lms-card mb-4">

        <div class="row g-3 align-items-end">

            <div class="col-lg-8">
                <label class="form-label fw-semibold">
                    Search Driver
                </label>

                <input class="form-control"
                       placeholder="Search by name, phone number or license..."
                       @bind="search" />
            </div>

            <div class="col-lg-4">

                <div class="d-flex gap-2">

                    <button class="btn btn-lms-primary flex-fill" @onclick="ApplyFilter">
                        <i class="bi bi-search"></i>
                        Search
                    </button>

                    <button class="btn btn-secondary flex-fill"
                            @onclick="Reset">
                        <i class="bi bi-arrow-clockwise"></i>
                        Reset
                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- Drivers Table -->
    <div class="lms-card">

        <div class="table-responsive">

            <table class="table lms-table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Phone Number</th>
                        <th>License Number</th>
                        <th width="220">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (drivers == null)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4">
                                Loading...
                            </td>
                        </tr>
                    }
                    else if (!drivers.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4">
                                No drivers found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var d in drivers)
                        {
                            <tr>

                                <td>
                                    <strong>@d.FullName</strong>
                                </td>

                                <td>@d.PhoneNumber</td>

                                <td>@d.LicenseNumber</td>

                                <td>

                                    <div class="d-flex gap-2">

                                        <a class="btn btn-sm btn-info"
                                           href="/drivers/details/@d.Id">
                                            <i class="bi bi-eye"></i>
                                            View
                                        </a>

                                        <a class="btn btn-sm btn-warning"
                                           href="/drivers/edit/@d.Id">
                                            <i class="bi bi-pencil-square"></i>
                                            Edit
                                        </a>

                                        <button class="btn btn-sm btn-danger"
                                                @onclick="() => Delete(d.Id)">
                                            <i class="bi bi-trash"></i>
                                            Delete
                                        </button>

                                    </div>

                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@code {

    List<Driver>? drivers;
    string? search;

    protected override async Task OnInitializedAsync()
    {
        drivers = await DriverService.GetAll();
    }

    async Task ApplyFilter()
    {
        drivers = await DriverService.GetFiltered(search);
    }

    async Task Reset()
    {
        search = null;
        drivers = await DriverService.GetAll();
    }

    async Task Delete(int id)
    {
        await DriverService.Delete(id);
        drivers = await DriverService.GetAll();
    }
}