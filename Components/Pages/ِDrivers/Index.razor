@page "/drivers"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject DriverService DriverService

<h3 class="mb-3">Drivers</h3>

<a class="btn btn-primary mb-3" href="/drivers/create">
    + Add Driver
</a>

<!-- 🔍 SEARCH -->
<div class="card p-3 mb-3 shadow-sm">

    <div class="row">

        <div class="col-md-8">
            <input class="form-control"
                   placeholder="Search by name, phone, license..."
                   @bind="search" />
        </div>

        <div class="col-md-4">
            <button class="btn btn-success me-2" @onclick="ApplyFilter">
                Search
            </button>

            <button class="btn btn-secondary" @onclick="Reset">
                Reset
            </button>
        </div>

    </div>

</div>

<!-- TABLE -->
<table class="table table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>Full Name</th>
            <th>Phone</th>
            <th>License</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (drivers == null)
        {
            <tr>
                <td colspan="4">Loading...</td>
            </tr>
        }
        else
        {
            @foreach (var d in drivers)
            {
                <tr>

                    <td>@d.FullName</td>
                    <td>@d.PhoneNumber</td>
                    <td>@d.LicenseNumber</td>

                    <td>
                        <a class="btn btn-sm btn-info"
                           href="/drivers/details/@d.Id">
                            View
                        </a>

                        <a class="btn btn-sm btn-warning"
                           href="/drivers/edit/@d.Id">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                @onclick="() => Delete(d.Id)">
                            Delete
                        </button>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>

@code {

    List<Driver>? drivers;
    string? search;

    protected override async Task OnInitializedAsync()
    {
        drivers = await DriverService.GetAll();
    }

    async Task ApplyFilter()
    {
        drivers = await DriverService.GetFiltered(search);
    }

    async Task Reset()
    {
        search = null;
        drivers = await DriverService.GetAll();
    }

    async Task Delete(int id)
    {
        await DriverService.Delete(id);
        drivers = await DriverService.GetAll();
    }
}