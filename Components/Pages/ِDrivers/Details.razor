@page "/drivers/details/{Id:int}"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject DriverService DriverService
@inject NavigationManager Nav

<div class="page-container">

    @if (driver == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <!-- DRIVER INFO -->
        <div class="lms-card">

            <h3 class="page-title">@driver.FullName</h3>

            <p><b>Phone:</b> @driver.PhoneNumber</p>
            <p><b>License:</b> @driver.LicenseNumber</p>

            <!-- ACTION BUTTONS -->
            <div class="mt-3">

                <button class="btn btn-warning"
                        @onclick="GoToEdit">
                    Edit
                </button>

                <button class="btn btn-secondary ms-2"
                        @onclick="GoBack">
                    Back
                </button>

            </div>

        </div>

        <br />

        <!-- LOAD HISTORY -->
        <div class="lms-card">

            <h5>🚚 Load History</h5>

            @if (loads == null || loads.Count == 0)
            {
                <p>No loads found for this driver.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table lms-table">

                        <thead>
                            <tr>
                                <th>Load No</th>
                                <th>Tracking</th>
                                <th>Status</th>
                                <th>Pickup</th>
                                <th>Delivery</th>
                                <th>Price</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var l in loads)
                            {
                                <tr>
                                    <td>@l.LoadNumber</td>
                                    <td>@l.TrackingNumber</td>

                                    <td>
                                        <span class="badge @GetStatusClass(l.Status)">
                                            @l.Status
                                        </span>
                                    </td>

                                    <td>@l.PickupDate.ToShortDateString()</td>
                                    <td>@(l.DeliveryDate?.ToShortDateString() ?? "-")</td>
                                    <td>@l.Price</td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }

        </div>
    }

</div>
@code {

    [Parameter]
    public int Id { get; set; }

    private Driver? driver;
    private List<Load>? loads;

    protected override async Task OnInitializedAsync()
    {
        driver = await DriverService.GetById(Id);
        loads = await DriverService.GetDriverLoads(Id);
    }

    // ✅ Navigation FIXED (NO $ inside Razor)
    void GoToEdit()
    {
        if (driver != null)
            Nav.NavigateTo($"/drivers/edit/{driver.Id}");
    }

    void GoBack()
    {
        Nav.NavigateTo("/drivers");
    }

    // 🎨 Status badge
    string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }
}