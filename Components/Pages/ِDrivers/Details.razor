@page "/drivers/details/{Id:int}"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject DriverService DriverService
@inject NavigationManager Nav

<div class="page-container">

    @if (driver == null)
    {
        <div class="lms-card text-center py-5">
            <p>Loading driver data...</p>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="page-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="page-title">Driver Details</h2>
                <p class="page-subtitle">View complete information for @driver.FullName</p>
            </div>
            <div>
                <span class="badge @(driver.IsActive ? "bg-success" : "bg-secondary")" style="font-size:1rem;">
                    @(driver.IsActive ? "Active" : "Inactive")
                </span>
            </div>
        </div>

        <!-- Driver Information Card -->
        <div class="lms-card">

            <div class="row g-4">

                <!-- Left Column -->
                <div class="col-md-6">
                    <h5 class="border-bottom pb-2 mb-3">Personal Information</h5>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Driver Code:</strong>
                        <span><code>@driver.DriverCode</code></span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Full Name:</strong>
                        <span>@driver.FullName</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>National Code:</strong>
                        <span>@driver.NationalCode</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Primary Phone:</strong>
                        <span>@driver.PhoneNumber</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Alternate Phone:</strong>
                        <span>@(string.IsNullOrEmpty(driver.AlternatePhoneNumber) ? "-" : driver.AlternatePhoneNumber)</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Birth Date:</strong>
                        <span>@(driver.BirthDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Address:</strong>
                        <span>@(string.IsNullOrEmpty(driver.Address) ? "-" : driver.Address)</span>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="col-md-6">
                    <h5 class="border-bottom pb-2 mb-3">License & Employment</h5>

                    <div class="d-flex justify-content-between py-2">
                        <strong>License Number:</strong>
                        <span>@driver.LicenseNumber</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>License Class:</strong>
                        <span>@(string.IsNullOrEmpty(driver.LicenseClass) ? "-" : driver.LicenseClass)</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>License Expiry:</strong>
                        <span>@(driver.LicenseExpiryDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Medical Exam Expiry:</strong>
                        <span>@(driver.MedicalExamExpiryDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Bank Account / IBAN:</strong>
                        <span>@(string.IsNullOrEmpty(driver.BankAccountNumber) ? "-" : driver.BankAccountNumber)</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Base Salary Rate:</strong>
                        <span>@(driver.SalaryBaseRate?.ToString("N0") ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Status:</strong>
                        <span class="badge @GetStatusBadgeClass(driver.Status)">
                            @driver.Status.ToString()
                        </span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Assigned Vehicle:</strong>
                        <span>
                            @if (driver.AssignedVehicle != null)
                            {
                                @($"{driver.AssignedVehicle.PlateNumber} - {driver.AssignedVehicle.Model}")
                            }
                            else
                            {
                                <span class="text-muted">Not assigned</span>
                            }
                        </span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Created At:</strong>
                        <span>@driver.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Last Updated:</strong>
                        <span>@(driver.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</span>
                    </div>
                </div>

            </div>

            <!-- Action Buttons -->
            <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                <button class="btn btn-warning" @onclick="GoToEdit">
                    <i class="bi bi-pencil-square"></i> Edit
                </button>
                <button class="btn btn-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back to List
                </button>
            </div>

        </div>

        <br />

        <!-- Load History Card -->
        <div class="lms-card">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">🚚 Load History</h5>
                <span class="badge bg-secondary">@(loads?.Count ?? 0) loads</span>
            </div>

            @if (loads == null || loads.Count == 0)
            {
                <p class="text-muted">No loads found for this driver.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table lms-table">

                        <thead>
                            <tr>
                                <th>Load No</th>
                                <th>Tracking</th>
                                <th>Status</th>
                                <th>Pickup</th>
                                <th>Delivery</th>
                                <th>Price</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var l in loads)
                            {
                                <tr>
                                    <td>@l.LoadNumber</td>
                                    <td>@l.TrackingNumber</td>

                                    <td>
                                        <span class="badge @GetStatusClass(l.Status)">
                                            @l.Status
                                        </span>
                                    </td>

                                    <td>@l.PickupDate.ToShortDateString()</td>
                                    <td>@(l.DeliveryDate?.ToShortDateString() ?? "-")</td>
                                    <td>@l.Price.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }

        </div>
    }

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Driver? driver;
    private List<Load>? loads;

    protected override async Task OnInitializedAsync()
    {
        driver = await DriverService.GetById(Id);
        loads = await DriverService.GetDriverLoads(Id);
    }

    void GoToEdit()
    {
        if (driver != null)
            Nav.NavigateTo($"/drivers/edit/{driver.Id}");
    }

    void GoBack()
    {
        Nav.NavigateTo("/drivers");
    }

    // Utility method for driver status badge
    string GetStatusBadgeClass(DriverStatus status)
    {
        return status switch
        {
            DriverStatus.Available => "bg-success",
            DriverStatus.OnTrip => "bg-primary",
            DriverStatus.Resting => "bg-warning",
            DriverStatus.Sick => "bg-danger",
            DriverStatus.OffDuty => "bg-secondary",
            DriverStatus.Unreachable => "bg-dark",
            _ => "bg-light"
        };
    }

    // Utility method for load status badge (as before)
    string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }
}