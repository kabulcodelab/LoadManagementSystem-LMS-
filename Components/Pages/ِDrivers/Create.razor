@page "/drivers/create"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject DriverService DriverService
@inject NavigationManager Nav

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">Create Driver</h2>
        <p class="page-subtitle">Add a new driver to the system</p>
    </div>

    <!-- FORM -->
    <div class="lms-card">

        <div class="row g-3 lms-form">

            <!-- Full Name -->
            <div class="col-12 col-md-6">
                <label>Full Name</label>
                <InputText class="form-control" @bind-Value="driver.FullName" />
            </div>

            <!-- Phone -->
            <div class="col-12 col-md-6">
                <label>Phone Number</label>
                <InputText class="form-control" @bind-Value="driver.PhoneNumber" />
            </div>

            <!-- License -->
            <div class="col-12 col-md-6">
                <label>License Number</label>
                <InputText class="form-control" @bind-Value="driver.LicenseNumber" />
            </div>

        </div>

        <!-- BUTTONS -->
        <div class="d-flex flex-wrap gap-2 mt-4">

            <button class="btn btn-add" @onclick="Save">
                + Save Driver
            </button>

            <button class="btn btn-secondary" @onclick="Cancel">
                Cancel
            </button>

        </div>

    </div>

</div>

@code {

    private Driver driver = new();

    private async Task Save()
    {
        await DriverService.Add(driver);
        Nav.NavigateTo("/drivers");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/drivers");
    }
}