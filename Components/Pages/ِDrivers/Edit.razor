@page "/drivers/edit/{Id:int}"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject DriverService DriverService
@inject NavigationManager Nav

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">Edit Driver</h2>
    </div>

    @if (driver == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <EditForm Model="driver" OnValidSubmit="Update">

            <DataAnnotationsValidator />

            <div class="lms-card lms-form">

                <div class="mb-3">
                    <label>Full Name</label>
                    <InputText class="form-control" @bind-Value="driver.FullName" />
                </div>

                <div class="mb-3">
                    <label>Phone Number</label>
                    <InputText class="form-control" @bind-Value="driver.PhoneNumber" />
                </div>

                <div class="mb-3">
                    <label>License Number</label>
                    <InputText class="form-control" @bind-Value="driver.LicenseNumber" />
                </div>

                <button type="submit" class="btn btn-lms-primary">
                    Update
                </button>

                <button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">
                    Cancel
                </button>

            </div>

        </EditForm>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    Driver? driver;

    protected override async Task OnInitializedAsync()
    {
        driver = await DriverService.GetById(Id);
    }

    async Task Update()
    {
        await DriverService.Update(driver!);
        Nav.NavigateTo("/drivers");
    }

    void Cancel()
    {
        Nav.NavigateTo("/drivers");
    }
}