@page "/documents"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop

@inject DocumentService DocumentService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<div class="container-fluid px-3 px-md-4 py-3">

    <!-- HEADER -->
    <div class="row align-items-center mb-4">
        <div class="col-12 col-md-8">
            <h2 class="page-title mb-0">Documents</h2>
            <p class="page-subtitle text-muted mb-0">Manage all uploaded files for loads</p>
        </div>
        <div class="col-12 col-md-4 text-md-end mt-2 mt-md-0">
            <span class="badge bg-secondary" style="font-size:1rem;">
                Total: @(pagedResult?.TotalCount ?? 0) files
            </span>
        </div>
    </div>

    <!-- ALERT -->
    @if (ShowAlert)
    {
        <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
            <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
            <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
        </div>
    }

    <!-- SEARCH & FILTER -->
    <div class="lms-card mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">Load Number</label>
                <input class="form-control" placeholder="Search by load number..." @bind="searchLoadNumber" @bind:event="oninput" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">File Type</label>
                <select class="form-select" @bind="selectedFileType">
                    <option value="">All Types</option>
                    @foreach (DocumentType type in Enum.GetValues(typeof(DocumentType)))
                    {
                        <option value="@type">@GetDocumentTypeDisplayName(type)</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">From Date</label>
                <input type="date" class="form-control" @bind="fromDate" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold">To Date</label>
                <input type="date" class="form-control" @bind="toDate" />
            </div>
            <div class="col-12 col-md-2">
                <div class="d-flex gap-2">
                    <button class="btn btn-lms-primary w-100" @onclick="ApplyFilter">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-secondary w-100" @onclick="Reset">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="lms-card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>File Name</th>
                        <th>Type</th>
                        <th>Load #</th>
                        <th>Size</th>
                       
                        <th>Uploaded At</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pagedResult == null)
                    {
                        <tr><td colspan="7" class="text-center py-4">Loading...</td></tr>
                    }
                    else if (!pagedResult.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center py-4 text-muted">No documents found.</td></tr>
                    }
                    else
                    {
                        @foreach (var doc in pagedResult.Items)
                        {
                            <tr>
                                <td>
                                    <i class="bi bi-file-earmark me-1"></i>
                                    @doc.FileName
                                </td>
                                <td>
                                    <span class="badge @GetDocTypeBadge(doc.FileType)">
                                        @GetDocumentTypeDisplayName(doc.FileType)
                                    </span>
                                </td>
                                <td>
                                    <a href="/loads/details/@doc.LoadId" class="text-decoration-none">
                                        <code>@doc.Load?.LoadNumber</code>
                                    </a>
                                </td>
                                <td>@(doc.FileSize?.ToString("N0") ?? "-") bytes</td>
                                
                                <td>@doc.UploadedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-center flex-nowrap">
                                        <!-- View Button -->
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => ViewFile(doc.Id)"
                                                title="View">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <!-- Download Button -->
                                        <button class="btn btn-sm btn-outline-success"
                                                @onclick="() => DownloadFile(doc.Id)"
                                                title="Download">
                                            <i class="bi bi-download"></i>
                                        </button>
                                        <!-- Delete Button -->
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => ConfirmDelete(doc.Id, doc.FileName)"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @if (pagedResult != null && pagedResult.TotalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3 pt-2 border-top">
                <div class="text-muted small mb-2 mb-md-0">
                    Showing @((pagedResult.CurrentPage - 1) * pagedResult.PageSize + 1) -
                    @Math.Min(pagedResult.CurrentPage * pagedResult.PageSize, pagedResult.TotalCount)
                    of @pagedResult.TotalCount entries
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">«</button>
                        </li>
                        @for (int i = 1; i <= pagedResult.TotalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(i)">@i</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == pagedResult.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">»</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        else if (pagedResult != null && pagedResult.TotalCount > 0)
        {
            <div class="mt-3 pt-2 border-top text-muted small">
                Showing @pagedResult.TotalCount entries
            </div>
        }
    </div>

    <!-- DELETE CONFIRMATION MODAL -->
    @if (DeleteId.HasValue)
    {
        <div class="modal-backdrop fade show" style="display:block;"></div>
        <div class="modal show d-block" tabindex="-1" role="dialog" style="display:block;">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete file <strong>@DeleteFileName</strong>?</p>
                        <p class="text-danger">This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger" @onclick="ExecuteDelete">Yes, Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<!-- ============================================= -->
<!-- JavaScript functions for View & Download      -->
<!-- ============================================= -->
<script>
    // View file in new tab
    window.viewBase64File = function (base64String, contentType, fileName) {
        try {
            const byteCharacters = atob(base64String);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray], { type: contentType });
            const url = URL.createObjectURL(blob);
            window.open(url, '_blank');
            setTimeout(() => URL.revokeObjectURL(url), 60000);
        } catch (error) {
            console.error('Error viewing file:', error);
            alert('Could not open the file. Please try downloading it.');
        }
    };

    // Download file directly
    window.downloadBase64File = function (base64String, fileName) {
        try {
            const byteCharacters = atob(base64String);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray]);
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            setTimeout(() => URL.revokeObjectURL(url), 60000);
        } catch (error) {
            console.error('Error downloading file:', error);
            alert('Could not download the file. Please try again.');
        }
    };
</script>

@code {
    // ===== Fields =====
    private PagedResult<Document>? pagedResult;
    private int currentPage = 1;
    private const int PageSize = 10;

    // Search / Filter
    private string? searchLoadNumber;
    private DocumentType? selectedFileType;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    // Delete
    private int? DeleteId;
    private string? DeleteFileName;

    // ===== Helper method for Display Name =====
    private string GetDocumentTypeDisplayName(DocumentType type)
    {
        return type switch
        {
            DocumentType.RateConfirmation => "Rate Confirmation",
            DocumentType.BillOfLading => "Bill of Lading",
            DocumentType.Others => "Others",
            _ => type.ToString()
        };
    }

    // ===== Lifecycle =====
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    // ===== Data Loading =====
    private async Task LoadData()
    {
        pagedResult = await DocumentService.GetPaged(
            page: currentPage,
            pageSize: PageSize,
            searchLoadNumber: searchLoadNumber,
            fileType: selectedFileType,
            fromDate: fromDate,
            toDate: toDate
        );
    }

    // ===== Search / Filter =====
    private async Task ApplyFilter()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task Reset()
    {
        searchLoadNumber = null;
        selectedFileType = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        await LoadData();
    }

    // ===== Pagination =====
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > pagedResult?.TotalPages) return;
        currentPage = page;
        await LoadData();
    }

    // ===== View File =====
    private async Task ViewFile(int docId)
    {
        try
        {
            var doc = await DocumentService.GetDocumentWithContent(docId);
            if (doc == null || doc.FileContent == null || doc.FileContent.Length == 0)
            {
                ShowAlertMessage("File content is empty or unavailable.", isError: true);
                return;
            }
            var base64 = Convert.ToBase64String(doc.FileContent);
            var mimeType = GetMimeType(doc.FileName);
            await JSRuntime.InvokeVoidAsync("viewBase64File", base64, mimeType, doc.FileName);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error viewing file: {ex.Message}", isError: true);
        }
    }

    // ===== Download File =====
    private async Task DownloadFile(int docId)
    {
        try
        {
            var doc = await DocumentService.GetDocumentWithContent(docId);
            if (doc == null || doc.FileContent == null || doc.FileContent.Length == 0)
            {
                ShowAlertMessage("File content is empty or unavailable.", isError: true);
                return;
            }
            var base64 = Convert.ToBase64String(doc.FileContent);
            await JSRuntime.InvokeVoidAsync("downloadBase64File", base64, doc.FileName);
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error downloading file: {ex.Message}", isError: true);
        }
    }

    // ===== Delete =====
    private void ConfirmDelete(int id, string fileName)
    {
        DeleteId = id;
        DeleteFileName = fileName;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        DeleteId = null;
        DeleteFileName = null;
        StateHasChanged();
    }

    private async Task ExecuteDelete()
    {
        if (DeleteId.HasValue)
        {
            try
            {
                await DocumentService.Delete(DeleteId.Value);
                CancelDelete();
                await LoadData();
                ShowAlertMessage($"File '{DeleteFileName}' deleted successfully.", isError: false);
            }
            catch (Exception ex)
            {
                ShowAlertMessage($"Error: {ex.Message}", isError: true);
            }
        }
    }

    // ===== Helper: Get MIME type from file name =====
    private string GetMimeType(string fileName)
    {
        var ext = Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "application/pdf",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".gif" => "image/gif",
            ".bmp" => "image/bmp",
            ".webp" => "image/webp",
            ".doc" => "application/msword",
            ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            ".xls" => "application/vnd.ms-excel",
            ".xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            ".ppt" => "application/vnd.ms-powerpoint",
            ".pptx" => "application/vnd.openxmlformats-officedocument.presentationml.presentation",
            ".txt" => "text/plain",
            ".csv" => "text/csv",
            ".zip" => "application/zip",
            ".rar" => "application/x-rar-compressed",
            ".7z" => "application/x-7z-compressed",
            ".xml" => "application/xml",
            ".json" => "application/json",
            _ => "application/octet-stream"
        };
    }

    // ===== Alert Helpers =====
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }

    // ===== Utility =====
    private string GetDocTypeBadge(DocumentType type)
    {
        return type switch
        {
            DocumentType.RateConfirmation => "bg-primary",
            DocumentType.BillOfLading => "bg-success",
            DocumentType.Others => "bg-secondary",
            _ => "bg-secondary"
        };
    }
}