@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]

@using LoadManagementSystem_LMS_.Data
@using LoadManagementSystem_LMS_.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager NavigationManager

<PageTitle>User Management</PageTitle>

<div class="container-fluid px-3 px-md-4 py-3">

    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title">User Management</h2>
            <p class="page-subtitle text-muted">Manage registered users and their access</p>
        </div>
        <a href="/" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <!-- ===== AuthorizeView: فقط کاربران Admin محتوای صفحه را ببینند ===== -->
    <AuthorizeView Roles="Admin">
        <Authorized>
            <!-- ALERT -->
            @if (ShowAlert)
            {
                <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
                    <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
                    <button type="button" class="btn-close" @onclick="CloseAlert"></button>
                </div>
            }

            <!-- USER TABLE -->
            <div class="lms-card">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Email Confirmed</th>
                                <th>Is Active</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (users == null)
                            {
                                <tr><td colspan="5" class="text-center py-4">Loading...</td></tr>
                            }
                            else if (!users.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">No users found.</td></tr>
                            }
                            else
                            {
                                @foreach (var user in users)
                                {
                                    <tr>
                                        <td>@user.FullName</td>
                                        <td>@user.Email</td>
                                        <td>
                                            <span class="badge @(user.EmailConfirmed ? "bg-success" : "bg-warning text-dark")">
                                                @(user.EmailConfirmed ? "Yes" : "No")
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                                                @(user.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1 justify-content-center flex-nowrap">
                                                <!-- Confirm Email -->
                                                @if (!user.EmailConfirmed)
                                                {
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => ConfirmUser(user.Id)" title="Confirm Email">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                }
                                                <!-- Toggle Active Status -->
                                                @if (user.IsActive)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleUserStatus(user.Id, false)" title="Deactivate">
                                                        <i class="bi bi-person-x"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => ToggleUserStatus(user.Id, true)" title="Activate">
                                                        <i class="bi bi-person-check"></i>
                                                    </button>
                                                }
                                                <!-- Delete User (Optional) -->
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(user.Id)" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="lms-card text-center py-5">
                <div class="text-danger" style="font-size: 4rem;">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h3 class="mt-3">Access Denied</h3>
                <p class="text-muted">You do not have permission to access this page.</p>
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house"></i> Return to Dashboard
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>

</div>

@code {
    private List<ApplicationUser>? users;

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await UserManager.Users.OrderByDescending(u => u.CreatedDate).ToListAsync();
    }

    // ===== Confirm Email =====
    private async Task ConfirmUser(string userId)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user != null)
            {
                user.EmailConfirmed = true;
                var result = await UserManager.UpdateAsync(user);
                if (result.Succeeded)
                {
                    await LoadUsers();
                    ShowAlertMessage($"User '{user.Email}' confirmed successfully.", isError: false);
                }
                else
                {
                    ShowAlertMessage($"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}", isError: true);
                }
            }
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    // ===== Toggle Active Status =====
    private async Task ToggleUserStatus(string userId, bool isActive)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user != null)
            {
                user.IsActive = isActive;
                var result = await UserManager.UpdateAsync(user);
                if (result.Succeeded)
                {
                    await LoadUsers();
                    ShowAlertMessage($"User '{user.Email}' {(isActive ? "activated" : "deactivated")} successfully.", isError: false);
                }
                else
                {
                    ShowAlertMessage($"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}", isError: true);
                }
            }
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    // ===== Delete User (Optional) =====
    private async Task DeleteUser(string userId)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user != null && user.Email != "admin@example.com") // Prevent deleting admin
            {
                var result = await UserManager.DeleteAsync(user);
                if (result.Succeeded)
                {
                    await LoadUsers();
                    ShowAlertMessage($"User '{user.Email}' deleted successfully.", isError: false);
                }
                else
                {
                    ShowAlertMessage($"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}", isError: true);
                }
            }
            else
            {
                ShowAlertMessage("Cannot delete the admin user.", isError: true);
            }
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    // ---- Alert helpers ----
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(3000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }
}