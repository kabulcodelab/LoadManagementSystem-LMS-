@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]

@using LoadManagementSystem_LMS_.Data
@using LoadManagementSystem_LMS_.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>User Management</PageTitle>

<div class="container-fluid px-3 px-md-4 py-3">

    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title">User Management</h2>
            <p class="page-subtitle text-muted">Manage registered users and their access</p>
        </div>
        <a href="/" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <!-- ===== AuthorizeView: Only Admin users see content ===== -->
    <AuthorizeView Roles="Admin">
        <Authorized>
            <!-- ALERT -->
            @if (ShowAlert)
            {
                <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
                    <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
                    <button type="button" class="btn-close" @onclick="CloseAlert"></button>
                </div>
            }

            <!-- USER TABLE -->
            <div class="lms-card">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Email Confirmed</th>
                                <th>Is Active</th>
                                <th class="text-center" style="min-width: 220px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (users == null)
                            {
                                <tr><td colspan="5" class="text-center py-4">Loading...</td></tr>
                            }
                            else if (!users.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">No users found.</td></tr>
                            }
                            else
                            {
                                @foreach (var user in users)
                                {
                                    <tr>
                                        <td>@user.FullName</td>
                                        <td>@user.Email</td>
                                        <td>
                                            <span class="badge @(user.EmailConfirmed ? "bg-success" : "bg-warning text-dark")">
                                                @(user.EmailConfirmed ? "Yes" : "No")
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                                                @(user.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                                <!-- Confirm Email -->
                                                @if (!user.EmailConfirmed)
                                                {
                                                    <button class="btn btn-sm btn-outline-success"
                                                            @onclick="() => ConfirmUser(user.Id)"
                                                            title="Confirm Email (allow login)">
                                                        <i class="bi bi-check-circle"></i> Confirm
                                                    </button>
                                                }

                                                <!-- Toggle Active Status -->
                                                @if (user.IsActive)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger"
                                                            @onclick="() => ToggleUserStatus(user.Id, false)"
                                                            title="Deactivate user (block login)">
                                                        <i class="bi bi-person-x"></i> Deactivate
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-success"
                                                            @onclick="() => ToggleUserStatus(user.Id, true)"
                                                            title="Activate user (allow login)">
                                                        <i class="bi bi-person-check"></i> Activate
                                                    </button>
                                                }

                                                <!-- Reset Password -->
                                                <button class="btn btn-sm btn-outline-warning"
                                                        @onclick="() => ResetPassword(user.Id, user.Email)"
                                                        title="Reset password and show new password">
                                                    <i class="bi bi-key"></i> Reset Password
                                                </button>

                                                <!-- Delete User -->
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => DeleteUser(user.Id)"
                                                        title="Permanently delete user">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="lms-card text-center py-5">
                <div class="text-danger" style="font-size: 4rem;">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h3 class="mt-3">Access Denied</h3>
                <p class="text-muted">You do not have permission to access this page.</p>
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house"></i> Return to Dashboard
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>

</div>

<!-- ===== RESET PASSWORD MODAL ===== -->
<div class="modal fade @(showResetPasswordModal ? "show d-block" : "")" tabindex="-1" role="dialog" style="@(showResetPasswordModal ? "display:block; background-color: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Password Reset for @(resetUserEmail)</h5>
                <button type="button" class="btn-close" @onclick="CloseResetPasswordModal"></button>
            </div>
            <div class="modal-body">
                <p>The password for <strong>@resetUserEmail</strong> has been reset.</p>
                <div class="alert alert-warning">
                    <strong>New password:</strong>
                    <code style="font-size: 1.2rem;">@newPassword</code>
                </div>
                <p class="text-muted small">Please share this password with the user. They should change it after logging in.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" @onclick="CopyPasswordToClipboard">
                    <i class="bi bi-clipboard"></i> Copy Password
                </button>
                <button class="btn btn-primary" @onclick="CloseResetPasswordModal">
                    <i class="bi bi-check"></i> Done
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ApplicationUser>? users;

    // Alert
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success";
    private CancellationTokenSource? _alertCts;

    // Reset Password Modal
    private bool showResetPasswordModal = false;
    private string resetUserEmail = string.Empty;
    private string newPassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        // Get current user's ID
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = authState.User;
        var currentUserId = UserManager.GetUserId(currentUser);

        var allUsers = await UserManager.Users.OrderByDescending(u => u.CreatedDate).ToListAsync();

        // Exclude the current admin from the list
        users = allUsers.Where(u => u.Id != currentUserId).ToList();
    }

    // ===== Confirm Email =====
    private async Task ConfirmUser(string userId)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user != null)
            {
                user.EmailConfirmed = true;
                var result = await UserManager.UpdateAsync(user);
                if (result.Succeeded)
                {
                    await LoadUsers();
                    ShowAlertMessage($"User '{user.Email}' confirmed successfully.", isError: false);
                }
                else
                {
                    ShowAlertMessage($"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}", isError: true);
                }
            }
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    // ===== Toggle Active Status =====
    private async Task ToggleUserStatus(string userId, bool isActive)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user != null)
            {
                user.IsActive = isActive;
                var result = await UserManager.UpdateAsync(user);
                if (result.Succeeded)
                {
                    await LoadUsers();
                    ShowAlertMessage($"User '{user.Email}' {(isActive ? "activated" : "deactivated")} successfully.", isError: false);
                }
                else
                {
                    ShowAlertMessage($"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}", isError: true);
                }
            }
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    // ===== Reset Password =====
    private async Task ResetPassword(string userId, string email)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user == null)
            {
                ShowAlertMessage("User not found.", isError: true);
                return;
            }

            // Generate a random password
            var generatedPassword = GenerateRandomPassword();

            // Reset the password
            var resetToken = await UserManager.GeneratePasswordResetTokenAsync(user);
            var result = await UserManager.ResetPasswordAsync(user, resetToken, generatedPassword);

            if (result.Succeeded)
            {
                // Store data for modal
                resetUserEmail = email;
                newPassword = generatedPassword;
                showResetPasswordModal = true;
                StateHasChanged();
                await LoadUsers(); // refresh table
            }
            else
            {
                ShowAlertMessage($"Error resetting password: {string.Join(", ", result.Errors.Select(e => e.Description))}", isError: true);
            }
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    private void CloseResetPasswordModal()
    {
        showResetPasswordModal = false;
        resetUserEmail = string.Empty;
        newPassword = string.Empty;
        StateHasChanged();
    }

    private async Task CopyPasswordToClipboard()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", newPassword);
        ShowAlertMessage("Password copied to clipboard!", isError: false);
    }

    // ===== Generate Random Password =====
    private string GenerateRandomPassword(int length = 12)
    {
        const string validChars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890!@#$%^&*()";
        var random = new Random();
        var password = new char[length];
        for (int i = 0; i < length; i++)
        {
            password[i] = validChars[random.Next(validChars.Length)];
        }
        return new string(password);
    }

    // ===== Delete User =====
    private async Task DeleteUser(string userId)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user != null)
            {
                // Extra safety: prevent deleting the current admin
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var currentUser = authState.User;
                var currentUserId = UserManager.GetUserId(currentUser);
                if (user.Id == currentUserId)
                {
                    ShowAlertMessage("You cannot delete your own admin account.", isError: true);
                    return;
                }

                var result = await UserManager.DeleteAsync(user);
                if (result.Succeeded)
                {
                    await LoadUsers();
                    ShowAlertMessage($"User '{user.Email}' deleted successfully.", isError: false);
                }
                else
                {
                    ShowAlertMessage($"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}", isError: true);
                }
            }
            else
            {
                ShowAlertMessage("User not found.", isError: true);
            }
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    // ---- Alert helpers ----
    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(3000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }
}