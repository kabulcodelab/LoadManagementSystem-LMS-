@page "/vehicles/details/{Id:int}"
@attribute [Authorize]
@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization

@inject VehicleService VehicleService

<PageTitle>Vehicle Details</PageTitle>

<div class="page-container">

    <div class="page-header">
        <div class="page-title">Vehicle Details</div>
        <div class="page-subtitle">Full information & load history</div>
    </div>

    @if (vehicle == null)
    {
        <div class="lms-card">Loading...</div>
    }
    else
    {
        <!-- VEHICLE INFO -->
        <div class="lms-card mb-3">

            <h4 class="mb-3">@vehicle.VehicleCode</h4>

            <div class="row">

                <div class="col-md-6">
                    <p><b>Plate Number:</b> @vehicle.PlateNumber</p>
                    <p><b>Model:</b> @vehicle.Model</p>
                    <p><b>Type:</b> @vehicle.VehicleType</p>
                </div>

                <div class="col-md-6">
                    <p><b>Capacity:</b> @vehicle.Capacity</p>
                    <p><b>Year:</b> @vehicle.ManufactureYear</p>

                    <p>
                        <b>Status:</b>
                        <span class="badge @(vehicle.IsActive ? "bg-success" : "bg-danger")">
                            @(vehicle.IsActive ? "Active" : "Inactive")
                        </span>
                    </p>
                </div>

            </div>
        </div>

        <!-- LOAD HISTORY -->
        <div class="lms-card">

            <h5 class="mb-3">🚚 Load History</h5>

            @if (loads == null)
            {
                <p>Loading...</p>
            }
            else if (loads.Count == 0)
            {
                <p>No loads found for this vehicle.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table lms-table">

                        <thead>
                            <tr>
                                <th>Load No</th>
                                <th>Tracking</th>
                                <th>Customer</th>
                                <th>Status</th>
                                <th>Pickup</th>
                                <th>Delivery</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var l in loads)
                            {
                                <tr>
                                    <td>@l.LoadNumber</td>
                                    <td>@l.TrackingNumber</td>
                                    <td>@l.Customer?.Name</td>

                                    <td>
                                        <span class="@GetStatusClass(l.Status)">
                                            @l.Status
                                        </span>
                                    </td>

                                    <td>@l.PickupDate.ToShortDateString()</td>

                                    <td>
                                        @(l.DeliveryDate?.ToShortDateString() ?? "-")
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }

        </div>

        <!-- ACTION BUTTONS -->
        <div class="mt-3 d-flex gap-2">

            <a class="btn btn-lms-gold"
               href="/vehicles/edit/@vehicle.Id">
                Edit
            </a>

            <a class="btn btn-secondary"
               href="/vehicles">
                Back
            </a>

        </div>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Vehicle? vehicle;
    private List<Load>? loads;

    protected override async Task OnInitializedAsync()
    {
        vehicle = await VehicleService.GetById(Id);

        // ⚠️ اگر هنوز این متد را نداری، باید در VehicleService اضافه شود
        loads = await VehicleService.GetVehicleLoads(Id);
    }

    string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "badge bg-secondary",
            LoadStatus.Assigned => "badge bg-primary",
            LoadStatus.PickedUp => "badge bg-info",
            LoadStatus.InTransit => "badge bg-warning text-dark",
            LoadStatus.Delivered => "badge bg-success",
            LoadStatus.Cancelled => "badge bg-danger",
            _ => "badge bg-dark"
        };
    }
}