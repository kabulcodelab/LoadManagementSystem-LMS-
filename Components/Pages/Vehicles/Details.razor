@page "/vehicles/details/{Id:int}"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components

@inject VehicleService VehicleService
@inject NavigationManager Nav

<PageTitle>Vehicle Details</PageTitle>

<div class="container-fluid px-3 px-md-4 py-3">

    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <div class="page-title">Vehicle Details</div>
            <div class="page-subtitle text-muted">Full information & load history</div>
        </div>
        <div>
            <span class="badge @(vehicle?.IsActive == true ? "bg-success" : "bg-secondary")" style="font-size:1rem;">
                @(vehicle?.IsActive == true ? "Active" : "Inactive")
            </span>
        </div>
    </div>

    <!-- Alert (for messages from other pages) -->
    @if (ShowAlert)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @AlertMessage
            <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
        </div>
    }

    @if (vehicle == null)
    {
        <div class="lms-card text-center py-5">
            <p>Loading vehicle data...</p>
        </div>
    }
    else
    {
        <!-- VEHICLE INFORMATION -->
        <div class="lms-card">

            <div class="row g-4">

                <!-- Left Column -->
                <div class="col-md-6">
                    <h5 class="border-bottom pb-2 mb-3">General Information</h5>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Vehicle Code:</strong>
                        <span><code>@vehicle.VehicleCode</code></span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Plate Number:</strong>
                        <span>@vehicle.PlateNumber</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>VIN (Chassis):</strong>
                        <span>@vehicle.VIN</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Engine Number:</strong>
                        <span>@(string.IsNullOrEmpty(vehicle.EngineNumber) ? "-" : vehicle.EngineNumber)</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Model:</strong>
                        <span>@vehicle.Model</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Vehicle Type:</strong>
                        <span>@vehicle.VehicleType</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Color:</strong>
                        <span>@(string.IsNullOrEmpty(vehicle.Color) ? "-" : vehicle.Color)</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Capacity:</strong>
                        <span>@vehicle.Capacity @vehicle.CapacityUnit</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Manufacture Year:</strong>
                        <span>@vehicle.ManufactureYear</span>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="col-md-6">
                    <h5 class="border-bottom pb-2 mb-3">Operational & Financial</h5>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Status:</strong>
                        <span class="badge @GetStatusBadgeClass(vehicle.Status)">
                            @vehicle.Status.ToString()
                        </span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Current Odometer (km):</strong>
                        <span>@(vehicle.CurrentOdometer?.ToString("N0") ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Last Service Date:</strong>
                        <span>@(vehicle.LastServiceDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Last Service Odometer (km):</strong>
                        <span>@(vehicle.LastServiceOdometer?.ToString("N0") ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Fuel Consumption (L/100km):</strong>
                        <span>@(vehicle.FuelConsumption?.ToString("N2") ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Cost Per Km:</strong>
                        <span>@(vehicle.CostPerKm?.ToString("N2") ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Purchase Date:</strong>
                        <span>@(vehicle.PurchaseDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Purchase Price:</strong>
                        <span>@(vehicle.PurchasePrice?.ToString("N0") ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Warranty Expiry:</strong>
                        <span>@(vehicle.WarrantyExpiryDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Inspection Expiry:</strong>
                        <span>@(vehicle.InspectionExpiryDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Insurance Expiry:</strong>
                        <span>@(vehicle.InsuranceExpiryDate?.ToShortDateString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Current Driver:</strong>
                        <span>
                            @if (vehicle.CurrentDriver != null)
                            {
                                @($"{vehicle.CurrentDriver.FullName} ({vehicle.CurrentDriver.DriverCode})")
                            }
                            else
                            {
                                <span class="text-muted">Not assigned</span>
                            }
                        </span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Created At:</strong>
                        <span>@vehicle.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <strong>Last Updated:</strong>
                        <span>@(vehicle.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</span>
                    </div>
                </div>

            </div>

            <!-- Action Buttons -->
            <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                <a class="btn btn-warning" href="/vehicles/edit/@vehicle.Id">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
                <button class="btn btn-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back to List
                </button>
            </div>

        </div>

        <br />

        <!-- LOAD HISTORY -->
        <div class="lms-card">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">🚚 Load History</h5>
                <span class="badge bg-secondary">@(loads?.Count ?? 0) loads</span>
            </div>

            @if (loads == null)
            {
                <p>Loading...</p>
            }
            else if (loads.Count == 0)
            {
                <p class="text-muted">No loads found for this vehicle.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table lms-table">

                        <thead>
                            <tr>
                                <th>Load No</th>
                                <th>Tracking</th>
                                <th>Customer</th>
                                <th>Status</th>
                                <th>Pickup</th>
                                <th>Delivery</th>
                                <th>Amount</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var l in loads)
                            {
                                <tr>
                                    <td>@l.LoadNumber</td>
                                    <td>@l.TrackingNumber</td>
                                    <td>@l.Customer?.Name</td>

                                    <td>
                                        <span class="badge @GetLoadStatusClass(l.Status)">
                                            @l.Status
                                        </span>
                                    </td>

                                    <td>@(l.PickupDate?.ToShortDateString() ?? "-")</td>

                                    <td>
                                        @(l.DeliveryDate?.ToShortDateString() ?? "-")
                                    </td>

                                    <td>@(l.Amount?.ToString("N0") ?? "-")</td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }

        </div>
    }

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    [Parameter]
    public string? Message { get; set; }

    private Vehicle? vehicle;
    private List<Load>? loads;

    // Alert properties
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private CancellationTokenSource? _alertCts;

    protected override async Task OnInitializedAsync()
    {
        vehicle = await VehicleService.GetById(Id);
        loads = await VehicleService.GetVehicleLoads(Id);
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Message))
        {
            ShowAlertMessage(Message);
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/vehicles");
    }

    // ---- Alert helpers ----
    private void ShowAlertMessage(string message)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }

    // ---- Utility methods ----
    private string GetStatusBadgeClass(VehicleStatus status)
    {
        return status switch
        {
            VehicleStatus.Available => "bg-success",
            VehicleStatus.OnTrip => "bg-primary",
            VehicleStatus.UnderMaintenance => "bg-warning",
            VehicleStatus.OutOfService => "bg-danger",
            VehicleStatus.Reserved => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetLoadStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }
}