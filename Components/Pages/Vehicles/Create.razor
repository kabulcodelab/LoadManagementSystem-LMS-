@page "/vehicles/create"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms

@inject VehicleService VehicleService
@inject DriverService DriverService
@inject NavigationManager Nav

<PageTitle>Create Vehicle</PageTitle>

<div class="page-container">

    <div class="page-header">
        <div class="page-title">Create Vehicle</div>
        <div class="page-subtitle">Add a new vehicle to the system</div>
    </div>

    <!-- Alert - now with dynamic type (success/danger) -->
    @if (ShowAlert)
    {
        <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
            <strong>@(AlertType == "danger" ? "Error!" : "Success!")</strong> @AlertMessage
            <button type="button" class="btn-close" @onclick="CloseAlert" aria-label="Close"></button>
        </div>
    }

    <div class="lms-card">

        <EditForm Model="@vehicle" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="row g-3 lms-form">

                <!-- Vehicle Code (auto-generated) -->
                <div class="col-12 col-md-4">
                    <label>Vehicle Code</label>
                    <InputText class="form-control" @bind-Value="vehicle.VehicleCode" disabled />
                    <small class="text-muted">Auto‑generated if left empty</small>
                </div>

                <!-- Plate Number (Required) -->
                <div class="col-12 col-md-4">
                    <label>Plate Number *</label>
                    <InputText class="form-control" @bind-Value="vehicle.PlateNumber" />
                    <ValidationMessage For="@(() => vehicle.PlateNumber)" />
                </div>

                <!-- VIN -->
                <div class="col-12 col-md-4">
                    <label>VIN (Chassis Number)</label>
                    <InputText class="form-control" @bind-Value="vehicle.VIN" />
                </div>

                <!-- Engine Number (Optional) -->
                <div class="col-12 col-md-4">
                    <label>Engine Number</label>
                    <InputText class="form-control" @bind-Value="vehicle.EngineNumber" />
                </div>

                <!-- Model (Required) -->
                <div class="col-12 col-md-4">
                    <label>Model *</label>
                    <InputText class="form-control" @bind-Value="vehicle.Model" />
                    <ValidationMessage For="@(() => vehicle.Model)" />
                </div>

                <!-- Vehicle Type (Required) -->
                <div class="col-12 col-md-4">
                    <label>Vehicle Type *</label>
                    <InputText class="form-control" @bind-Value="vehicle.VehicleType" />
                    <ValidationMessage For="@(() => vehicle.VehicleType)" />
                </div>

                <!-- Color (Optional) -->
                <div class="col-12 col-md-4">
                    <label>Color</label>
                    <InputText class="form-control" @bind-Value="vehicle.Color" />
                </div>

                <!-- Capacity (Required) -->
                <div class="col-12 col-md-4">
                    <label>Capacity * (kg)</label>
                    <InputNumber class="form-control" @bind-Value="vehicle.Capacity" />
                    <ValidationMessage For="@(() => vehicle.Capacity)" />
                </div>

                <!-- Capacity Unit -->
                <div class="col-12 col-md-4">
                    <label>Capacity Unit</label>
                    <InputSelect class="form-select" @bind-Value="vehicle.CapacityUnit">
                        <option value="kg">kg</option>
                        <option value="tons">tons</option>
                        <option value="lb">lb</option>
                    </InputSelect>
                </div>

                <!-- Manufacture Year -->
                <div class="col-12 col-md-4">
                    <label>Manufacture Year</label>
                    <InputNumber class="form-control" @bind-Value="vehicle.ManufactureYear" />
                </div>

                <!-- Status -->
                <div class="col-12 col-md-4">
                    <label>Status</label>
                    <InputSelect class="form-select" @bind-Value="vehicle.Status">
                        @foreach (VehicleStatus status in Enum.GetValues(typeof(VehicleStatus)))
                        {
                            <option value="@status">@status.ToString()</option>
                        }
                    </InputSelect>
                </div>

                <!-- Current Odometer -->
                <div class="col-12 col-md-4">
                    <label>Current Odometer (km)</label>
                    <InputNumber class="form-control" @bind-Value="vehicle.CurrentOdometer" />
                </div>

                <!-- Last Service Date -->
                <div class="col-12 col-md-4">
                    <label>Last Service Date</label>
                    <InputDate class="form-control" @bind-Value="vehicle.LastServiceDate" />
                </div>

                <!-- Last Service Odometer -->
                <div class="col-12 col-md-4">
                    <label>Last Service Odometer (km)</label>
                    <InputNumber class="form-control" @bind-Value="vehicle.LastServiceOdometer" />
                </div>

                <!-- Fuel Consumption -->
                <div class="col-12 col-md-4">
                    <label>Fuel Consumption (L/100km)</label>
                    <InputNumber class="form-control" @bind-Value="vehicle.FuelConsumption" />
                </div>

                <!-- Cost Per Km -->
                <div class="col-12 col-md-4">
                    <label>Cost Per Km</label>
                    <InputNumber class="form-control" @bind-Value="vehicle.CostPerKm" />
                </div>

                <!-- Purchase Date -->
                <div class="col-12 col-md-4">
                    <label>Purchase Date</label>
                    <InputDate class="form-control" @bind-Value="vehicle.PurchaseDate" />
                </div>

                <!-- Purchase Price -->
                <div class="col-12 col-md-4">
                    <label>Purchase Price</label>
                    <InputNumber class="form-control" @bind-Value="vehicle.PurchasePrice" />
                </div>

                <!-- Warranty Expiry -->
                <div class="col-12 col-md-4">
                    <label>Warranty Expiry Date</label>
                    <InputDate class="form-control" @bind-Value="vehicle.WarrantyExpiryDate" />
                </div>

                <!-- Inspection Expiry -->
                <div class="col-12 col-md-4">
                    <label>Inspection Expiry Date</label>
                    <InputDate class="form-control" @bind-Value="vehicle.InspectionExpiryDate" />
                </div>

                <!-- Insurance Expiry -->
                <div class="col-12 col-md-4">
                    <label>Insurance Expiry Date</label>
                    <InputDate class="form-control" @bind-Value="vehicle.InsuranceExpiryDate" />
                </div>

                <!-- Current Driver -->
                <div class="col-12 col-md-4">
                    <label>Current Driver</label>
                    <InputSelect class="form-select" @bind-Value="vehicle.CurrentDriverId">
                        <option value="">None</option>
                        @foreach (var driver in drivers)
                        {
                            <option value="@driver.Id">@driver.FullName - @driver.DriverCode</option>
                        }
                    </InputSelect>
                </div>

                <!-- Is Active -->
                <div class="col-12 col-md-4 d-flex align-items-center">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="vehicle.IsActive" />
                        <label class="form-check-label">Active</label>
                    </div>
                </div>

            </div>

            <div class="d-flex flex-wrap gap-2 mt-4">
                <button type="submit" class="btn btn-add">Save Vehicle</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>

        </EditForm>

    </div>

</div>

@code {
    private Vehicle vehicle = new();
    private List<Driver> drivers = new();

    // Alert properties with dynamic type
    private bool ShowAlert = false;
    private string AlertMessage = string.Empty;
    private string AlertType = "success"; // "success" or "danger"
    private CancellationTokenSource? _alertCts;

    protected override async Task OnInitializedAsync()
    {
        var allDrivers = await DriverService.GetAll();
        drivers = allDrivers.Where(d => d.IsActive).ToList();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            await VehicleService.Add(vehicle);
            ShowAlertMessage($"Vehicle '{vehicle.PlateNumber}' was added successfully!", isError: false);
            await Task.Delay(1000);
            Nav.NavigateTo("/vehicles");
        }
        catch (Exception ex)
        {
            ShowAlertMessage($"Error: {ex.Message}", isError: true);
        }
    }

    private void ShowAlertMessage(string message, bool isError = false)
    {
        _alertCts?.Cancel();
        _alertCts = new CancellationTokenSource();

        AlertMessage = message;
        ShowAlert = true;
        AlertType = isError ? "danger" : "success";
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, _alertCts.Token);
            if (!_alertCts.Token.IsCancellationRequested)
            {
                await InvokeAsync(() =>
                {
                    ShowAlert = false;
                    AlertMessage = string.Empty;
                    StateHasChanged();
                });
            }
        });
    }

    private void CloseAlert()
    {
        _alertCts?.Cancel();
        ShowAlert = false;
        AlertMessage = string.Empty;
        StateHasChanged();
    }

    private void Cancel()
    {
        Nav.NavigateTo("/vehicles");
    }
}