@page "/vehicles"

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services

@inject VehicleService VehicleService

<h3 class="mb-3">Vehicles</h3>

<a class="btn btn-primary mb-3" href="/vehicles/create">
    + Add Vehicle
</a>

<!-- 🔍 SEARCH -->
<div class="card p-3 mb-3 shadow-sm">

    <div class="row">

        <div class="col-md-8">
            <input class="form-control"
                   placeholder="Search by code, plate, model, type..."
                   @bind="search" />
        </div>

        <div class="col-md-4">

            <button class="btn btn-success me-2"
                    @onclick="ApplyFilter">
                Search
            </button>

            <button class="btn btn-secondary"
                    @onclick="Reset">
                Reset
            </button>

        </div>

    </div>

</div>

<!-- TABLE -->
<table class="table table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>Code</th>
            <th>Plate</th>
            <th>Model</th>
            <th>Type</th>
            <th>Capacity</th>
            <th>Year</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (vehicles == null)
        {
            <tr>
                <td colspan="8">Loading...</td>
            </tr>
        }
        else
        {
            @foreach (var v in vehicles)
            {
                <tr>

                    <td>@v.VehicleCode</td>
                    <td>@v.PlateNumber</td>
                    <td>@v.Model</td>
                    <td>@v.VehicleType</td>
                    <td>@v.Capacity</td>
                    <td>@v.ManufactureYear</td>

                    <td>
                        <span class="badge @(v.IsActive ? "bg-success" : "bg-danger")">
                            @(v.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>

                    <td>
                        <a class="btn btn-info btn-sm"
                           href="/vehicles/details/@v.Id">
                            View
                        </a>

                        <a class="btn btn-sm btn-warning"
                           href="/vehicles/edit/@v.Id">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                @onclick="() => Delete(v.Id)">
                            Delete
                        </button>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>
@code {

    List<Vehicle>? vehicles;
    string? search;

    protected override async Task OnInitializedAsync()
    {
        vehicles = await VehicleService.GetFiltered(null);
    }

    async Task ApplyFilter()
    {
        vehicles = await VehicleService.GetFiltered(search);
    }

    async Task Reset()
    {
        search = null;
        vehicles = await VehicleService.GetFiltered(null);
    }

    private async Task Delete(int id)
    {
        await VehicleService.Delete(id);
        vehicles = await VehicleService.GetFiltered(search);
    }
}