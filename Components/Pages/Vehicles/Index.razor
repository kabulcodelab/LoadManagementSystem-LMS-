@page "/vehicles"
@attribute [Authorize]
@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@inject VehicleService VehicleService

<PageTitle>Vehicles</PageTitle>

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <div class="page-title">Vehicles</div>
            <div class="page-subtitle">Manage all transport vehicles</div>
        </div>

        <a class="btn btn-add" href="/vehicles/create">
            + Add Vehicle
        </a>
    </div>

    <!-- SEARCH -->
    <div class="search-panel">
        <div class="row g-2">

            <div class="col-md-9 col-12">
                <input class="form-control"
                       placeholder="Search by code, plate, model, type..."
                       @bind="search" />
            </div>

            <div class="col-md-3 col-12 d-flex gap-2">

                <button class="btn btn-lms-primary w-100"
                        @onclick="ApplyFilter">
                    Search
                </button>

                <button class="btn btn-secondary w-100"
                        @onclick="Reset">
                    Reset
                </button>

            </div>

        </div>
    </div>

    <!-- TABLE -->
    <div class="table-responsive lms-card">

        <table class="table lms-table mb-0">

            <thead>
                <tr>
                    <th>Code</th>
                    <th>Plate</th>
                    <th>Model</th>
                    <th>Type</th>
                    <th>Capacity</th>
                    <th>Year</th>
                    <th>Status</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (vehicles == null)
                {
                    <tr>
                        <td colspan="8">Loading...</td>
                    </tr>
                }
                else if (!vehicles.Any())
                {
                    <tr>
                        <td colspan="8">No vehicles found</td>
                    </tr>
                }
                else
                {
                    @foreach (var v in vehicles)
                    {
                        <tr>

                            <td>@v.VehicleCode</td>
                            <td>@v.PlateNumber</td>
                            <td>@v.Model</td>
                            <td>@v.VehicleType</td>
                            <td>@v.Capacity</td>
                            <td>@v.ManufactureYear</td>

                            <td>
                                <span class="badge @(v.IsActive ? "bg-success" : "bg-danger")">
                                    @(v.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>

                            <td class="d-flex gap-1">

                                <a class="btn btn-info btn-sm"
                                   href="/vehicles/details/@v.Id">
                                    View
                                </a>

                                <a class="btn btn-warning btn-sm"
                                   href="/vehicles/edit/@v.Id">
                                    Edit
                                </a>

                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => Delete(v.Id)">
                                    Delete
                                </button>

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>

@code {

    List<Vehicle>? vehicles;
    string? search;

    protected override async Task OnInitializedAsync()
    {
        vehicles = await VehicleService.GetAll();
    }

    async Task ApplyFilter()
    {
        // اگر later filter service داشتی اینجا تغییر بده
        vehicles = await VehicleService.GetAll();

        if (!string.IsNullOrWhiteSpace(search))
        {
            vehicles = vehicles
                .Where(x =>
                    x.VehicleCode.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    x.PlateNumber.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    x.Model.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    x.VehicleType.Contains(search, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    async Task Reset()
    {
        search = null;
        vehicles = await VehicleService.GetAll();
    }

    private async Task Delete(int id)
    {
        await VehicleService.Delete(id);
        vehicles = await VehicleService.GetAll();
    }
}