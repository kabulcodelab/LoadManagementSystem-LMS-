@page "/"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Models
@using LoadManagementSystem_LMS_.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop

@inject DashboardService DashboardService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Overview of system performance</p>
        </div>
    </div>

    <!-- LOADING SPINNER -->
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading dashboard data...</p>
        </div>
    }
    else
    {
        <!-- KPI SECTION -->
        <div class="row g-3">

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="kpi-card border-start border-primary border-4 shadow-sm" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/loads")'>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Total Loads</h6>
                            <h3>@data.TotalLoads</h3>
                        </div>
                        <div class="kpi-icon">🚚</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="kpi-card border-start border-warning border-4 shadow-sm" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/loads?status=Pending")'>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Pending</h6>
                            <h3>@data.PendingLoads</h3>
                        </div>
                        <div class="kpi-icon">⏳</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="kpi-card border-start border-success border-4 shadow-sm" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/loads?status=Delivered")'>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Delivered</h6>
                            <h3>@data.DeliveredLoads</h3>
                        </div>
                        <div class="kpi-icon">✅</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="kpi-card border-start border-info border-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Revenue</h6>
                            <h3>$@data.TotalRevenue.ToString("N0")</h3>
                        </div>
                        <div class="kpi-icon">💰</div>
                    </div>
                </div>
            </div>

        </div>

        <br />

        <!-- SECOND ROW -->
        <div class="row g-3">

            <div class="col-12 col-md-4">
                <div class="kpi-card shadow-sm" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/drivers")'>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Drivers</h6>
                            <h3>@data.Drivers</h3>
                        </div>
                        <div class="kpi-icon">👨‍✈️</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="kpi-card shadow-sm" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/vehicles")'>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Vehicles</h6>
                            <h3>@data.Vehicles</h3>
                        </div>
                        <div class="kpi-icon">🚛</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="kpi-card shadow-sm" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/customers")'>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Customers</h6>
                            <h3>@data.Customers</h3>
                        </div>
                        <div class="kpi-icon">🏢</div>
                    </div>
                </div>
            </div>

        </div>

        <br />

        <!-- ============================================= -->
        <!-- CHART SECTION                                -->
        <!-- ============================================= -->
        <div class="row g-3 mb-4">

            <div class="col-12 col-md-6">
                <div class="lms-card">
                    <h6 class="mb-3">Load Status Distribution</h6>
                    <div style="height: 250px;">
                        <canvas id="loadStatusChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="lms-card">
                    <h6 class="mb-3">Daily Revenue (Last 7 Days)</h6>
                    <div style="height: 250px;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>

        </div>

        <!-- ============================================= -->
        <!-- RECENT LOADS TABLE                           -->
        <!-- ============================================= -->
        <div class="lms-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">📋 Recent Loads</h5>
                <a href="/loads" class="btn btn-sm btn-outline-primary">View All</a>
            </div>

            @if (data.RecentLoads.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Load #</th>
                                <th>Customer</th>
                                <th>Status</th>
                                <th>Amount</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var load in data.RecentLoads)
                            {
                                <tr>
                                    <td><code>@load.LoadNumber</code></td>
                                    <td>@load.CustomerName</td>
                                    <td><span class="badge @GetStatusClass(load.Status)">@load.Status</span></td>
                                    <td>@(load.Amount?.ToString("N0") ?? "-")</td>
                                    <td>@load.CreatedDate.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No recent loads found.</p>
            }
        </div>
    }

</div>

@code {
    private DashboardData data = new();
    private bool isLoading = true;
    private bool chartsLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            data = await DashboardService.GetDashboardData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // ✅ Call LoadCharts after the component is rendered (DOM is ready)
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !chartsLoaded)
        {
            await LoadCharts();
            chartsLoaded = true;
        }
    }

    // ================================================
    // بارگذاری نمودارها
    // ================================================
    private async Task LoadCharts()
    {
        try
        {
            // 1. نمودار دایره‌ای – وضعیت بارها
            var statusData = await DashboardService.GetLoadStatusDistribution();

            var labels = new[] { "Pending", "In Transit", "Delivered", "Cancelled" };
            var values = new[] { statusData.Pending, statusData.InTransit, statusData.Delivered, statusData.Cancelled };
            var colors = new[] { "#ffc107", "#0dcaf0", "#198754", "#dc3545" };

            await JSRuntime.InvokeVoidAsync("createChart",
                "loadStatusChart",
                "doughnut",
                labels,
                new[]
                {
                    new
                    {
                        data = values,
                        backgroundColor = colors,
                        borderWidth = 1
                    }
                },
                new
                {
                    responsive = true,
                    maintainAspectRatio = false,
                    plugins = new
                    {
                        legend = new { position = "bottom" }
                    }
                }
            );

            // 2. نمودار میله‌ای – درآمد روزانه
            var dailyRevenue = await DashboardService.GetDailyRevenue(7);
            var dateLabels = dailyRevenue.Keys.Select(d => d.ToString("MM/dd")).ToArray();
            var revenueValues = dailyRevenue.Values.ToArray();

            await JSRuntime.InvokeVoidAsync("createChart",
                "revenueChart",
                "bar",
                dateLabels,
                new[]
                {
                    new
                    {
                        label = "Revenue ($)",
                        data = revenueValues,
                        backgroundColor = "#0d6efd",
                        borderRadius = 4
                    }
                },
                new
                {
                    responsive = true,
                    maintainAspectRatio = false,
                    plugins = new
                    {
                        legend = new { display = false }
                    },
                    scales = new
                    {
                        y = new
                        {
                            beginAtZero = true,
                            ticks = new
                            {
                                callback = "function(value) { return '$' + value; }"
                            }
                        }
                    }
                }
            );
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading charts: {ex.Message}");
        }
    }

    // ================================================
    // متد کمکی برای کلاس وضعیت
    // ================================================
    private string GetStatusClass(LoadStatus status)
    {
        return status switch
        {
            LoadStatus.Pending => "bg-secondary",
            LoadStatus.Assigned => "bg-primary",
            LoadStatus.PickedUp => "bg-info",
            LoadStatus.InTransit => "bg-warning text-dark",
            LoadStatus.Delivered => "bg-success",
            LoadStatus.Cancelled => "bg-danger",
            _ => "bg-dark"
        };
    }
}