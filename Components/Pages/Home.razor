@page "/"
@attribute [Authorize]

@using LoadManagementSystem_LMS_.Data
@using LoadManagementSystem_LMS_.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Db

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h1 class="page-title">Dashboard</h1>
        <div class="page-subtitle">Overview of system performance</div>
    </div>

    <!-- KPI SECTION -->
    <div class="row g-3">

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi-card border-start border-primary border-4 shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Total Loads</h6>
                        <h3>@totalLoads</h3>
                    </div>
                    <div class="kpi-icon">🚚</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi-card border-start border-warning border-4 shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Pending</h6>
                        <h3>@pendingLoads</h3>
                    </div>
                    <div class="kpi-icon">⏳</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi-card border-start border-success border-4 shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Delivered</h6>
                        <h3>@deliveredLoads</h3>
                    </div>
                    <div class="kpi-icon">✅</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi-card border-start border-info border-4 shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Revenue</h6>
                        <h3>$@totalRevenue</h3>
                    </div>
                    <div class="kpi-icon">💰</div>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- SECOND ROW -->
    <div class="row g-3">

        <div class="col-12 col-md-4">
            <div class="kpi-card shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Drivers</h6>
                        <h3>@drivers</h3>
                    </div>
                    <div class="kpi-icon">👨‍✈️</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="kpi-card shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Vehicles</h6>
                        <h3>@vehicles</h3>
                    </div>
                    <div class="kpi-icon">🚛</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="kpi-card shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Customers</h6>
                        <h3>@customers</h3>
                    </div>
                    <div class="kpi-icon">🏢</div>
                </div>
            </div>
        </div>

    </div>

</div>
@code {

    private int totalLoads;
    private int pendingLoads;
    private int deliveredLoads;
    private int drivers;
    private int vehicles;
    private int customers;
    private decimal totalRevenue;

    protected override async Task OnInitializedAsync()
    {
        totalLoads = await Db.Loads.CountAsync();
        pendingLoads = await Db.Loads.CountAsync(x => x.Status == LoadStatus.Pending);
        deliveredLoads = await Db.Loads.CountAsync(x => x.Status == LoadStatus.Delivered);

        drivers = await Db.Drivers.CountAsync();
        vehicles = await Db.Vehicles.CountAsync();
        customers = await Db.Customers.CountAsync();

        totalRevenue = await Db.Loads
            .Where(x => x.Status == LoadStatus.Delivered)
            .SumAsync(x => x.Price);
    }
}